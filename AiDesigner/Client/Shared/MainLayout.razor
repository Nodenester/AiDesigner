@code {
    public string Title { get; set; } = "";
    public List<ProgramObject> APs = new List<ProgramObject>();
    public List<ProgramObject> EAPs = new List<ProgramObject>();
    public ProgramObject AP = null;
    private string _currentUri;
    public WorkshopArticle passingArticle;
    private List<ApiKey> apiKeys = new List<ApiKey>();

    public List<WorkshopArticle> workshopArticles { get; set; }

    public ChacheAnalytics analytics = new ChacheAnalytics();

    public Tutorial CurrentTutorial;

    public Wallet CurrentTokens { get; set; } = new Wallet();

    public AuthenticationState AuthState { get; set; }

    private bool isDarkMode = true;

    public EventCallback<Tutorial> setTutorial => EventCallback.Factory.Create<Tutorial>(this, SetTutorial);

    public EventCallback<ChacheAnalytics> setAnalytic => EventCallback.Factory.Create<ChacheAnalytics>(this, SetAnalytic);

    public EventCallback<ProgramObject> NewAps => EventCallback.Factory.Create<ProgramObject>(this, AddAps);

    public EventCallback<Wallet> setTokens => EventCallback.Factory.Create<Wallet>(this, SetTokens);

    public EventCallback<ProgramObject> setAp => EventCallback.Factory.Create<ProgramObject>(this, SetAP);

    public EventCallback<WorkshopArticle> setPassingArticle => EventCallback.Factory.Create<WorkshopArticle>(this, SetPassingArticle);

    public EventCallback<ApiKey> addApiKey => EventCallback.Factory.Create<ApiKey>(this, AddApiKey);

    public void SetAnalytic(ChacheAnalytics Analytics)
    {
        if (Analytics.last100Calls != null)
        {
            analytics.last100Calls = Analytics.last100Calls;
        }
        if (Analytics.programItems != null)
        {
            analytics.programItems = Analytics.programItems;
        }
        if (Analytics.sourceItems != null)
        {
            analytics.sourceItems = Analytics.sourceItems;
        }
        if (Analytics.workshopArticles != null)
        {
            analytics.workshopArticles = Analytics.workshopArticles;
        }
        if (Analytics.newsArticle != null)
        {
            analytics.newsArticle = Analytics.newsArticle;
        }
        if (Analytics.tutorials != null)
        {
            analytics.tutorials = Analytics.tutorials;
        }
    }

    public async Task SetTutorial(Tutorial tutorial)
    {
        shouldRender = false;
        CurrentTutorial = tutorial;
        await Task.Delay(20);
        shouldRender = true;
    }

    public void Completetutorial(Tutorial tutorial)
    {
        analytics.tutorials[tutorial.TutorialId -1] = tutorial;
    }

    public void SetTokens(Wallet tokens)
    {
        CurrentTokens = tokens;
    }

    public void AddAps(ProgramObject ap)
    {
        if(!APs.Contains(ap))
        {
            APs.Add(ap);
            SetAP(ap);
        }
        else
        {
            SetAP(ap);
        }
    }

    public void SetPassingArticle(WorkshopArticle article)
    {
        passingArticle = article;
    }

    public void AddApiKey(ApiKey apiKey)
    {
        apiKeys.Add(apiKey);
    }

    protected override async Task OnInitializedAsync()
    {
        Http.Timeout = TimeSpan.FromMinutes(10);
        //NavigationManagers.LocationChanged += HandleLocationChanged;
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        await UpdatePrograms();
        await GetTokens();
        await GetApiKeys();
        await UpdateVault();

        // var uri = new Uri(NavigationManagers.Uri); // Get the current URL
        // if (uri.AbsolutePath == "/library" || uri.AbsolutePath == "/editor" || uri.AbsolutePath == "/marketplace")
        // {
        //     shouldRender = true;
        // }
        // else
        // {
        //     shouldRender = false;
        // }
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        AuthState = task.Result;
        UpdatePrograms();
    }

    private async Task UpdatePrograms()
    {
        AuthState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = AuthState.User;
        if (user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
            if (!string.IsNullOrEmpty(userIdClaim) && Guid.TryParse(userIdClaim, out Guid userId))
            {
                try
                {
                    var response = await Http.GetAsync($"Programs/user/{userId}");
                    if (response.IsSuccessStatusCode)
                    {
                        var responseContent = await response.Content.ReadAsStringAsync();
                        var settings = new JsonSerializerSettings
                            {
                                TypeNameHandling = TypeNameHandling.Auto,
                                Converters = new List<JsonConverter> { new TupleConverter(), new BlockJsonConverter() },
                                ContractResolver = new DefaultContractResolver
                                {
                                    NamingStrategy = new CamelCaseNamingStrategy()
                                },
                                ReferenceLoopHandling = ReferenceLoopHandling.Serialize,
                                ObjectCreationHandling = ObjectCreationHandling.Replace
                            };
                        var userPrograms = JsonConvert.DeserializeObject<List<ProgramObject>>(responseContent, settings);
                        EAPs = userPrograms.ToList();
                        Console.WriteLine(EAPs.Count);   // this happens but it dont show in the pagese under it just when the page is changed 
                    }
                    else
                    {
                        // Read the response content which should contain the error message
                        var errorMessage = await response.Content.ReadAsStringAsync();
                        Console.WriteLine($"HTTP request failed with status code: {response.StatusCode}, message: {errorMessage}");
                    }

                }
                catch (HttpRequestException ex)
                {
                    // Handle or log the HTTP request exception here...
                    Console.WriteLine($"HTTP request exception: {ex.Message}");
                }
                catch (JsonException ex)
                {
                    // Handle or log the deserialization exception here...
                    Console.WriteLine($"Failed to deserialize response: {ex.Message}");
                }
            }
        }
    }

    private async Task GetTokens()
    {
        AuthState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = AuthState.User;
        if (user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
            if (!string.IsNullOrEmpty(userIdClaim) && Guid.TryParse(userIdClaim, out Guid userId))
            {
                try
                {
                    var response = await Http.PostAsJsonAsync<Guid>("Chat/Wallet/GetCreateWallet", userId);

                    if (response.IsSuccessStatusCode)
                    {
                        CurrentTokens = await response.Content.ReadFromJsonAsync<Wallet>();
                    }
                }
                catch (HttpRequestException ex)
                {
                    // Handle or log the HTTP request exception here...
                    Console.WriteLine($"HTTP request exception: {ex.Message}");
                }
                catch (JsonException ex)
                {
                    // Handle or log the deserialization exception here...
                    Console.WriteLine($"Failed to deserialize response: {ex.Message}");
                }
            }
        }
    }

    private async Task GetApiKeys()
    {
        if (AuthState != null)
        {
            var user = AuthState.User;
            var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
            if (Guid.TryParse(userIdClaim, out Guid userId))
            {
                var response = await Http.GetAsync($"Chat/ApiKey/GetByUserId/{userId}");
                if (response.IsSuccessStatusCode)
                {
                    try
                    {
                        apiKeys = await response.Content.ReadFromJsonAsync<List<ApiKey>>();
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine(ex.Message);
                    }
                }
            }
        }
    }

    public async Task SetEAPs()
    {
        var user = AuthState.User;
        if (user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out Guid userId))
            {
                var userPrograms = await Http.GetFromJsonAsync<IEnumerable<ProgramObject>>($"Programs/user/{userId}");
                EAPs = userPrograms.ToList();
            }
        }
    }

    public void RemoveProject(ProgramObject projectToRemove)
    {
        APs.Remove(projectToRemove);

        if (AP == projectToRemove)
        {
            AP = null;
            NavigationManagers.NavigateTo("library");
        }
    }

    public void SetAP(ProgramObject ap)
    {
        AP = ap;
        NavigationManagers.NavigateTo("editor");
    }

    public void ResetAP()
    {
        AP = null;

        NavigationManagers.NavigateTo("library");
    }

    private async Task ToggleDarkMode()
    {
        shouldRender = false;
        isDarkMode = !isDarkMode;
        await JSRuntime.InvokeVoidAsync("toggleDarkMode");
        await Task.Delay(20);
        shouldRender = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var newUri = NavigationManagers.Uri;

        if (_currentUri != newUri)
        {
            _currentUri = newUri;
            UpdateTitleFromUri();
        }
    }

    private void UpdateTitleFromUri()
    {
        Title = NavigationManagers.ToBaseRelativePath(NavigationManagers.Uri).ToLower();
        StateHasChanged();
    }

    private bool shouldRender = true;
    protected override bool ShouldRender()
    {
        return shouldRender;
    }

    //Vault
    public async Task UpdateVault()
    {
        if (AuthState?.User != null && workshopArticles == null)
        {
            var user = AuthState.User;

            if (user.Identity.IsAuthenticated)
            {
                var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
                if (Guid.TryParse(userIdClaim, out Guid userId))
                {
                    try
                    {
                        var response = await Http.GetAsync($"Workshop/get-articles-connected-to-user/{userId}");
                        if (response.IsSuccessStatusCode)
                        {
                            // Deserialize the response to the expected data model.
                            workshopArticles = (await response.Content.ReadFromJsonAsync<IEnumerable<WorkshopArticle>>()).ToList();
                        }
                        else
                        {
                            Console.WriteLine($"The call failed with status code {response.StatusCode}");
                        }
                    }
                    catch (HttpRequestException ex)
                    {
                        Console.WriteLine($"Request exception: {ex.Message}");
                    }
                }
            }
        }
    }


@code {
    public string Title { get; set; } = "";
    public List<ProgramObject> APs = new List<ProgramObject>();
    public List<ProgramObject> EAPs = new List<ProgramObject>();
    public ProgramObject AP = null;
    private string _currentUri;

    public AuthenticationState AuthState { get; set; }

    private bool isDarkMode = true;

    public EventCallback<ProgramObject> NewAps => EventCallback.Factory.Create<ProgramObject>(this, AddAps);

    public void AddAps(ProgramObject ap)
    {
        if(!APs.Contains(ap))
        {
            APs.Add(ap);
            SetAP(ap);
        }
        else
        {
            SetAP(ap);
        }
    }

    //Make this update when loggin in and other stuff and make it api     this might work
    protected override async Task OnInitializedAsync()
    {
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        await UpdatePrograms();
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        AuthState = task.Result;
        UpdatePrograms();
    }

    private async Task UpdatePrograms()
    {
        AuthState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = AuthState.User;
        if (user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
            if (!string.IsNullOrEmpty(userIdClaim) && Guid.TryParse(userIdClaim, out Guid userId))
            {
                try
                {
                    var response = await Http.GetAsync($"Programs/user/{userId}");
                    if (response.IsSuccessStatusCode)
                    {
                        var responseContent = await response.Content.ReadAsStringAsync();
                        var settings = new JsonSerializerSettings
                            {
                                TypeNameHandling = TypeNameHandling.Auto,
                                Converters = new List<JsonConverter> { new TupleConverter(), new BlockJsonConverter() },
                                ContractResolver = new DefaultContractResolver
                                {
                                    NamingStrategy = new CamelCaseNamingStrategy()
                                },
                                ReferenceLoopHandling = ReferenceLoopHandling.Serialize,
                                ObjectCreationHandling = ObjectCreationHandling.Replace
                            };
                        var userPrograms = JsonConvert.DeserializeObject<List<ProgramObject>>(responseContent, settings);
                        EAPs = userPrograms.ToList();
                        Console.WriteLine(EAPs.Count);   // this happens but it dont show in the pagese under it just when the page is changed 
                    }
                    else
                    {
                        // Read the response content which should contain the error message
                        var errorMessage = await response.Content.ReadAsStringAsync();
                        Console.WriteLine($"HTTP request failed with status code: {response.StatusCode}, message: {errorMessage}");
                    }

                }
                catch (HttpRequestException ex)
                {
                    // Handle or log the HTTP request exception here...
                    Console.WriteLine($"HTTP request exception: {ex.Message}");
                }
                catch (JsonException ex)
                {
                    // Handle or log the deserialization exception here...
                    Console.WriteLine($"Failed to deserialize response: {ex.Message}");
                }
            }
        }
    }

    public async Task SetEAPs()
    {
        var user = AuthState.User;
        if (user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out Guid userId))
            {
                var userPrograms = await Http.GetFromJsonAsync<IEnumerable<ProgramObject>>($"Programs/user/{userId}");
                EAPs = userPrograms.ToList();
            }
        }
    }

    public void RemoveProject(ProgramObject projectToRemove)
    {
        APs.Remove(projectToRemove);

        if (AP == projectToRemove)
        {
            AP = null;
            NavigationManagers.NavigateTo("library");
        }
    }

    public void SetAP(ProgramObject ap)
    {
        AP = ap;
        NavigationManagers.NavigateTo("editor");
    }

    public void ResetAP()
    {
        AP = null;

        NavigationManagers.NavigateTo("library");
    }

    private async Task ToggleDarkMode()
    {
        isDarkMode = !isDarkMode;
        await JSRuntime.InvokeVoidAsync("toggleDarkMode");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var newUri = NavigationManagers.Uri;

        if (_currentUri != newUri)
        {
            _currentUri = newUri;
            UpdateTitleFromUri();
        }
    }

    private void UpdateTitleFromUri()
    {
        Title = NavigationManagers.ToBaseRelativePath(NavigationManagers.Uri).ToLower();
        StateHasChanged();
    }
}



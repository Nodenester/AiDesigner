@using NodeBaseApi.Version2;
@inject HttpClient Http;
@inject NavigationManager NavigationManager;

<div class="text-center p-4 overflow-y-auto">
    <p class="text-lg font-semibold mb-4">Latest News</p>
    @if (analytics.newsArticle != null)
    {
        @foreach (var article in analytics.newsArticle)
        {
            <div class="mb-2">
                <button class="w-full h-auto p-2 rounded-lg shadow hover:shadow-lg transition
                        @(selectedArticle == article ? "dark:bg-gray-500 bg-gray-100" : "dark:bg-gray-600 bg-gray-200") text-black"
                @onclick="() => SetSelectedNewsArticle(article)">
                    <div class="truncate dark:text-white text-lg">@article.Title</div>
                    <div>@article.PublishDate.ToShortDateString()</div>
                    @if (selectedArticle == article)
                    {
                        <div class="mt-2 flex flex-col items-center">
                            @if (article.ImageData != null)
                            {
                                <img src="@($"data:image/png;base64,{Convert.ToBase64String(article.ImageData)}")" alt="@article.Title" style="width: 300px; height: 300px; object-fit: cover; border-radius: 4px; margin-bottom: 8px;" loading="lazy" />
                            }
                            <p class="dark:text-white">@article.Content</p>
                        </div>
                    }
                    else
                    {
                        <div class="mt-2">
                            <p class="truncate dark:text-white">@article.Content.Substring(0, 50)...</p>
                        </div>
                    }
                </button>
            </div>
        }
    }
</div>

@code{
    [CascadingParameter(Name = "analytics")]
    public ChacheAnalytics analytics { get; set; }

    [Parameter]
    public NewsArticle initialArticle { get; set; }

    private NewsArticle selectedArticle;

    public bool shouldRender = true;

    protected override void OnParametersSet()
    {
        selectedArticle = initialArticle;
        base.OnParametersSet();
        //shouldRender = false;
    }

    private void SetSelectedNewsArticle(NewsArticle article)
    {
        // shouldRender = true;
        selectedArticle = article;
        // StateHasChanged();
        // shouldRender = false;
    }

    // protected override bool ShouldRender()
    // {
    //     return shouldRender;
    // }
}

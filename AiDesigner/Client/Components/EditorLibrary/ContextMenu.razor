@inject IJSRuntime JSRuntime

<div id="contextMenu" class="context-menu hidden overflow-y-scroll overflow-x-visible bg-gray-700 absolute z-10" style="border-radius: 0.625rem; width: 16rem; height: 16rem;">
    <input id="searchInput" type="text" placeholder="Search..." @oninput="UpdateFilter" class="px-1 py-1 w-full border-b-2 border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:outline-none" />
    <ul class="px-1 py-0 dark:bg-gray-700">
        @RenderItems(FilteredItems)
    </ul>
</div>

<style>
    /* The emerging W3C standard that is currently Firefox compatible only */
    * {
        scrollbar-width: thin;
        scrollbar-color: gray transparent;
    }

        /* Works on Chrome/Edge/Safari */
        *::-webkit-scrollbar {
            width: 5px;
        }

        *::-webkit-scrollbar-track {
            background: transparent;
        }

        *::-webkit-scrollbar-thumb {
            background-color: gray;
            border-radius: 20px;
            transition: width 0.3s;
        }

            *::-webkit-scrollbar-thumb:hover {
                width: 10px;
            }

    .context-menu ul {
        padding-left: 14px;
    }
</style>

@code {
    [Parameter]
    public EventCallback<Item> OnMenuItemClick { get; set; }

    private string filter = "";

    private IEnumerable<Item> FilteredItems => GetFilteredAndExpandedItems(Items, filter);

    private bool IsMatch(Item item, string filter)
    {
        bool match = !string.IsNullOrWhiteSpace(filter) && item.Name.ToLower().Contains(filter.ToLower());
        bool anySubItemMatches = item.SubItems?.Any(subItem => IsMatch(subItem, filter)) ?? false;

        // Set IsExpanded only if there is a filter string and it's a match or an ancestor of a matching item.
        item.IsExpanded = match || anySubItemMatches;

        return match || anySubItemMatches;
    }

    private IEnumerable<Item> GetFilteredAndExpandedItems(IEnumerable<Item> items, string filter)
    {
        var filteredItems = new List<Item>();

        foreach (var item in items)
        {
            if (string.IsNullOrWhiteSpace(filter))
            {
                // If there's no filter, add all items but make sure they are not expanded.
                item.IsExpanded = false;
                filteredItems.Add(item);
            }
            else if (IsMatch(item, filter))
            {
                // Only add items that are a match or have matching subitems.
                filteredItems.Add(item);
            }
        }

        return filteredItems;
    }

    private void UpdateFilter(ChangeEventArgs e)
    {
        filter = e.Value.ToString();
        StateHasChanged(); // Re-render the component with the updated filter.
    }

    private RenderFragment RenderItems(IEnumerable<Item> items) => builder =>
       {
           var seq = 0;
           foreach (var item in items)
           {
               builder.OpenComponent<MenuItem>(seq++);
               builder.AddAttribute(seq++, "Item", item);
               builder.AddAttribute(seq++, "OnItemClick", OnMenuItemClick);

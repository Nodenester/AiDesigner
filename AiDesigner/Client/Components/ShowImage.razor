@page "/ImageComponent"
@inject HttpClient Http

@code {
    [Parameter] public byte[] ImageData { get; set; }
    private string imageUrl;

    protected override async Task OnParametersSetAsync()
    {
        if (ImageData != null && ImageData.Length > 0)
        {
            var response = await Http.PostAsJsonAsync<byte[]>("api/Images", ImageData);
            if (response.IsSuccessStatusCode)
            {
                imageUrl = await response.Content.ReadAsStringAsync();
            }
            else
            {
                Console.Error.WriteLine($"Failed to upload image: {response.ReasonPhrase}");
            }
        }
    }
}

@if (imageUrl != null)
{
    <img src="@imageUrl" alt="Image" style="width:100%; height:260px; object-fit:cover; border-radius:4px; margin-bottom:8px;" loading="lazy" />
}

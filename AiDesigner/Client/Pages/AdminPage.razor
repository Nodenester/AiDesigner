@page "/Admin-Page"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@attribute [Authorize(Roles = "Administrator")]

<div class="flex flex-col bg-gray-100 dark:bg-gray-600 mb-0" style="height: 79%;">
    <!-- Header or Navbar could go here -->
    <div class="flex-grow flex flex-row">
        <!-- Column 1 -->
        <div class="p-4 border-r border-gray-300 dark:border-gray-700 bg-gray-700 rounded-lg">
            <AiDesigner.Client.Modals.AddNews/>
        </div>
        <!-- Column 2 -->
        <div class="flex-grow p-4 border-r border-gray-300 dark:border-gray-700">
            <!-- Column 2 content goes here -->
        </div>
        <!-- Column 3 -->
        <div class="flex-grow p-4">
            <!-- Column 3 content goes here -->
        </div>
    </div>
    <!-- Footer could go here -->
</div>

@code {
    [CascadingParameter(Name = "CascAuth")]
    public AuthenticationState authState { get; set; }

    protected override async Task OnInitializedAsync()
    {

    }
}

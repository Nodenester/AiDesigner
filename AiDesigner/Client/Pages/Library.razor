    private async Task RemoveArticle(string id)
    {
        try
        {
            var user = CascAuth.User;
            var userIdClaim = user.Claims.FirstOrDefault()?.Value;
            if (Guid.TryParse(userIdClaim, out Guid userId))
            {
                var response = await Http.DeleteAsync($"Workshop/remove-user-article/{userId}/{id}");

                Console.WriteLine("Article id: " + id);

                if (response.IsSuccessStatusCode)
                {
                    Console.WriteLine("Article removed successfully");
                    workshopArticles.RemoveAll(article => article.Id == id);
                    StateHasChanged();
                }
                else
                {
                    // Log or display the error
                    Console.WriteLine($"Failed to remove article connection. Status code: {response.StatusCode}");
                }
            }
        }
        catch (HttpRequestException ex)
        {
            // Log or display the error
            Console.WriteLine($"Request error: {ex.Message}");
        }
    }

    private async Task CloneArticle(string id)
    {
        var response = await Http.GetAsync($"Programs/{id}");
        if (response.IsSuccessStatusCode)
        {
            var responseContent = await response.Content.ReadAsStringAsync();
            var settings = new JsonSerializerSettings
            {
                TypeNameHandling = TypeNameHandling.Auto,
                Converters = new List<JsonConverter> { new BlockJsonConverter() },
                ContractResolver = new DefaultContractResolver { NamingStrategy = new CamelCaseNamingStrategy() },
                ReferenceLoopHandling = ReferenceLoopHandling.Serialize,
                ObjectCreationHandling = ObjectCreationHandling.Replace
            };

            var jobject = JObject.Parse(responseContent);
            var programStructureToken = jobject["programStructure"] as JObject;

            Tuple<int, int> programStartLocation = null, programEndLocation = null;
            Tuple<double, double> cameraPos = null;

            if (programStructureToken != null)
            {
                var startLocationArray = programStructureToken["programStartLocation"] as JArray;
                if (startLocationArray != null && startLocationArray.Count >= 2)
                {
                    programStartLocation = new Tuple<int, int>(startLocationArray[0].Value<int>(), startLocationArray[1].Value<int>());
                    programStructureToken.Remove("programStartLocation");
                }

                var endLocationArray = programStructureToken["programEndLocation"] as JArray;
                if (endLocationArray != null && endLocationArray.Count >= 2)
                {
                    programEndLocation = new Tuple<int, int>(endLocationArray[0].Value<int>(), endLocationArray[1].Value<int>());
                    programStructureToken.Remove("programEndLocation");
                }

                var cameraPosArray = programStructureToken["cameraPos"] as JArray;
                if (cameraPosArray != null && cameraPosArray.Count >= 2)
                {
                    cameraPos = new Tuple<double, double>(cameraPosArray[0].Value<double>(), cameraPosArray[1].Value<double>());
                    programStructureToken.Remove("cameraPos");
                }
            }

            ProgramObject userProgram;
            if (responseContent.Contains("\"apiKey\":"))
            {
                userProgram = JsonConvert.DeserializeObject<CustomProgram>(jobject.ToString(), settings);
            }
            else
            {
                userProgram = JsonConvert.DeserializeObject<CustomBlockProgram>(jobject.ToString(), settings);
            }


            // Assign the tuples directly to the ProgramObject's structure
            if (userProgram != null && userProgram.ProgramStructure != null)
            {
                userProgram.ProgramStructure.ProgramStartLocation = null;
                userProgram.ProgramStructure.ProgramEndLocation = null;
                userProgram.ProgramStructure.CameraPos = null;
                userProgram.ProgramStructure.ProgramStartLocation = programStartLocation;
                userProgram.ProgramStructure.ProgramEndLocation = programEndLocation;
                userProgram.ProgramStructure.CameraPos = cameraPos;

                Console.WriteLine(userProgram.ProgramStructure.ProgramStartLocation.Item1 + " " + userProgram.ProgramStructure.ProgramStartLocation.Item2);
                Console.WriteLine(userProgram.ProgramStructure.ProgramEndLocation.Item1 + " " + userProgram.ProgramStructure.ProgramEndLocation.Item2);
                Console.WriteLine(userProgram.ProgramStructure.CameraPos.Item1 + " " + userProgram.ProgramStructure.CameraPos.Item2);

            }

            if (userProgram is CustomProgram customProgram)
            {
                if (customProgram.IsPublic)
                {
                    ap.Open();
                    NewProgram = customProgram;
                }
                else
                {
                    Console.WriteLine("CustomProgram is not public");
                }
            }
            else if(userProgram is CustomBlockProgram customBlockProgram)
            {
                if (customBlockProgram.IsPublic)
                {
                    ap.Open();
                    NewBlockProgram = customBlockProgram;
                }
                else
                {
                    Console.WriteLine("Custom¨BlockProgram is not public");
                }
            }
        }
        else
        {
            // Log or display the error
            Console.WriteLine($"Failed to get article for cloning. Status code: {response.StatusCode}");
        }
    }

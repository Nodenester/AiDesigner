@*Här ska man testa programet eller blocket? och inställningar för project*@

<ProgramSettings SelectedProgram="AP" SelectedProgramChanged="OnSelectedProgramChanged"></ProgramSettings>
<br />

<CascadingValue Value="NewProgram" Name="NP">
<div style="display: flex; align-items: center; justify-content: space-between;">
    <h1 style="margin-right: 10px;">My projects</h1>
    <hr style="flex-grow: 1; margin: 0;">
    <AiDesigner.Client.Modals.AddProgram @ref="ap" CreateNew="CreateProgram"></AiDesigner.Client.Modals.AddProgram>
</div>
</CascadingValue>

<div class="flex flex-wrap gap-4 mt-8">
    @foreach (var eap in EAPs.OrderByDescending(e => e.LastOpened))
    {
        if (eap is CustomProgram customProgram)
        {
            <button class="w-72 h-48 p-0 rounded bg-gray-200 dark:bg-gray-700 text-black dark:text-white flex flex-col items-center justify-between relative custom-button"
            @onmousedown="@(async () => await HandleButtonClick(eap))"
            @ondblclick="@(async () => await HandleDButtonClick(customProgram))">

                <!-- X Button - Initially Hidden, Shown on Hover -->
                <button @onclick="(() => RemoveProject(customProgram.Id))"
                        class="absolute top-0 right-0 p-0 m-1 text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white close-button">
                    X
                </button>

                <!-- Image -->
                @if (customProgram.Image != null)
                {
                    <div class="w-full h-4/5">
                        <img src="@($"data:image/png;base64,{Convert.ToBase64String(customProgram.Image)}")" alt="@customProgram.Name" style="width: 100%; height: 100%; object-fit: cover; flex-grow: 1;" class="rounded-t" loading="lazy" />
                    </div>
                }
                else
                {
                    <div style="margin-top: 9.7rem;" />
                }

                <!-- Divider -->
                <hr style="width: 100%; margin-left: auto; margin-right: auto;">

                <!-- Program Name -->
                <div class="w-full align-middle content-center">
                    <h1 class="dark:text-white mb-2 text-xl m-auto">@customProgram.Name</h1>
                </div>
            </button>
        }
    }
</div>
<br />

<CascadingValue Value="NewBlockProgram" Name="NCB">
    <div style="display: flex; align-items: center; justify-content: space-between;">
        <h1 style="margin-right: 10px;">My custom blocks</h1>
        <hr style="flex-grow: 1; margin: 0;">
        <AiDesigner.Client.Modals.AddCustomBlock @ref="acb" CreateNew="CreateBlockProgram"></AiDesigner.Client.Modals.AddCustomBlock>
    </div>
</CascadingValue>

<div class="flex flex-wrap gap-4 mt-8">
    @foreach (var eap in EAPs.OrderByDescending(e => e.LastOpened))
    {
        if (eap is CustomBlockProgram customBlockProgram)
        {
            <button class="w-72 h-48 p-0 rounded bg-gray-200 dark:bg-gray-700 text-black dark:text-white flex flex-col items-center justify-between relative custom-button"
            @onmousedown="@(async () => await HandleButtonClick(eap))"
            @ondblclick="@(async () => await HandleDButtonClick(customBlockProgram))">

                <!-- X Button - Initially Hidden, Shown on Hover -->
                <button @onclick="(() => RemoveProject(customBlockProgram.Id))"
                        class="absolute top-0 right-0 p-0 m-1 text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white close-button">
                    X
                </button>

                <!-- Image -->
                @if (customBlockProgram.Image != null)
                {
                    <div class="w-full h-4/5">
                        <img src="@($"data:image/png;base64,{Convert.ToBase64String(customBlockProgram.Image)}")" alt="@customBlockProgram.Name" style="width: 100%; height: 100%; object-fit: cover; flex-grow: 1;" class="rounded-t" loading="lazy" />
                    </div>
                }
                else
                {
                    <div style="margin-top: 9.7rem;" />
                }

                <!-- Divider -->
                <hr style="width: 100%; margin-left: auto; margin-right: auto;">

                <!-- Program Name -->
                <div class="w-full align-middle content-center">
                    <h1 class="dark:text-white mb-2 text-xl m-auto">@customBlockProgram.Name</h1>
                </div>
            </button>
        }
    }
</div>

<div style="display: flex; align-items: center; justify-content: space-between;" class="mt-8">
    <h1 style="margin-right: 10px;">Vault</h1>
    <hr style="flex-grow: 1; margin: 0;">
</div>

<div class="flex flex-wrap gap-4 mt-8">
    @if (workshopArticles != null)
    {
        @foreach (var article in workshopArticles.OrderBy(a => !a.IsPublic))
        {
            <div class="relative rounded bg-gray-200 dark:bg-gray-700 text-black dark:text-white flex custom-button" style="width: 18rem; height: 9.84rem;">

                <!-- Remove Button -->
                <button @onclick="(() => RemoveArticle(article.Id.ToString()))" class="absolute top-0 right-0 p-0 m-1 text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white close-button">
                    X
                </button>

                <!-- Image Container -->
                <div style="width: 9.75rem; height: 9.75rem; position: relative; padding-left: 9.6rem;">
                    <img src="@($"data:image/png;base64,{Convert.ToBase64String(article.ProgramImage)}")" alt="@article.Name" style="min-width: 9rem; min-height: 9rem; max-width: 9rem; max-height: 9rem; object-fit: cover; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);" />
                </div>

                <!-- Text and Clone Button -->
                <div class="flex flex-col ml-4" style="height: 100%;">
                    <!-- Name -->
                    <div class="overflow-hidden" style="max-height: 55%; margin-left: 0.24rem; word-wrap: break-word;">
                        <h3 class="dark:text-white text-2xl">@article.Name</h3>
                    </div>

                    <!-- Program/CustomBlock Label and Clone Button -->
                    <div class="mt-auto pb-5" style="max-height: 45%;">
                        <!-- Program/CustomBlock Label -->
                        @if (article.ApiKey == "xxx")
                        {
                            <p class="dark:text-white text-xl">CustomBlock</p>
                        }
                        else
                        {
                            <p class="dark:text-white text-xl">Program</p>
                        }

                        <!-- Clone Button -->
                        @if (article.IsPublic)
                        {
                            <button @onclick="(() => CloneArticle(article.ProgramId))" class="py-1 bg-green-600 hover:bg-green-700 text-white rounded" style="padding-left: 1.8rem; padding-right: 1.8rem;">
                                Clone
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .custom-button:hover .close-button {
        opacity: 1 !important;
    }

    .close-button {
        opacity: 0;
        transition: opacity 0.3s ease-in-out;
    }
</style>


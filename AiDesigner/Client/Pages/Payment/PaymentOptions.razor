@page "/paymentoptions"
@using NodeBaseApi.Version2
@inject HttpClient Http
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Authorization;
@attribute [Authorize]

<div class="dark:!bg-gray-600 bg-white">
    <div class="container px-6 py-8 mx-auto">
        <div class="flex flex-col items-center justify-center space-y-8 lg:-mx-4 lg:flex-row lg:items-stretch lg:space-y-0"
            <div class="flex flex-col w-full max-w-sm p-8 space-y-8 text-center bg-white rounded-lg lg:mx-4 @(wallet.SubscriptionTier == 0 ? "border-4 border-green-500" : "border-0 border-gray-200") dark:!bg-gray-800">
                <div class="flex-shrink-0">
                    <h2 class="inline-flex items-center justify-center px-2 font-semibold tracking-tight text-green-600 uppercase rounded-lg bg-gray-50 dark:bg-gray-700">
                        Testing
                    </h2>
                </div>
                <div class="flex-shrink-0">
                    <span class="pt-2 text-4xl font-bold text-gray-800 uppercase dark:text-gray-100">
                        Free
                    </span>
                </div>
                <ul class="flex-1 space-y-4">
                    <li class="text-gray-500 dark:text-gray-400">
                        Up 500 tokens per day
                    </li>
                    <li class="text-gray-500 dark:text-gray-400">
                        unlimited projects
                    </li>
                    <li class="text-gray-500 dark:text-gray-400">
                        Up to 5 session
                    </li>
                </ul>

                <!-- Start/Cancel Button -->
                @if (wallet.SubscriptionTier > 0 && wallet.StripeSubscriptionId != null)
                {
                    <button @onclick="CancelSubscription"
                            class="inline-flex items-center justify-center px-4 py-2 font-semibold text-white uppercase bg-red-600 rounded-lg hover:bg-red-700 focus:outline-none">
                        Cancel Subscription
                    </button>
                }
                else
                {
                    <a href="home" class="inline-flex items-center justify-center px-4 py-2 font-semibold text-white uppercase transition-colors bg-green-600 rounded-lg hover:bg-green-700 focus:outline-none">
                        Start free
                    </a>
                }
            </div>

            <div class="flex flex-col w-full max-w-sm p-8 space-y-8 text-center bg-white rounded-lg lg:mx-4 @(wallet.SubscriptionTier == 1 ? "border-4 border-green-500" : "border-0 border-gray-200") dark:!bg-gray-800">
                <div class="flex-shrink-0">
                    <h2 class="inline-flex items-center justify-center px-2 font-semibold tracking-tight text-green-600 uppercase rounded-lg bg-gray-50 dark:bg-gray-700">
                        Casual
                    </h2>
                </div>
                <div class="flex-shrink-0">
                    <span class="pt-2 text-4xl font-bold text-gray-800 uppercase dark:text-gray-100">
                        $9.99
                    </span>
                    <span class="text-gray-500 dark:text-gray-400">
                        /month
                    </span>
                </div>
                <ul class="flex-1 space-y-4">
                    <li class="text-gray-500 dark:text-gray-400">
                        Up to 2000 tokens per day
                    </li>
                    <li class="text-gray-500 dark:text-gray-400">
                        unlimited projects
                    </li>
                    <li class="text-gray-500 dark:text-gray-400">
                        Up to 20 session
                    </li>
                </ul>

            <button @onclick="() => InvokeAppropriateAction(2000)"
                    class="@(wallet.SubscriptionTier == 1 ? "bg-gray-400 cursor-not-allowed" : "bg-green-600 hover:bg-green-700") inline-flex items-center justify-center px-4 py-2 font-semibold text-white uppercase transition-colors rounded-lg focus:outline-none">
                                @(wallet.SubscriptionTier == 1 ? "Current Plan" : (wallet.SubscriptionTier > 0 ? "Change Plan" : "Start Subscription"))
            </button>
            </div>

            <div class="flex flex-col w-full max-w-sm p-8 space-y-8 text-center bg-white rounded-lg lg:mx-4 @(wallet.SubscriptionTier == 2 ? "border-4 border-green-500" : "border-0 border-gray-200") dark:!bg-gray-800">
                <div class="flex-shrink-0">
                    <h2 class="inline-flex items-center justify-center px-2 font-semibold tracking-tight text-green-600 uppercase rounded-lg bg-gray-50 dark:bg-gray-700">
                        Profesional
                    </h2>
                </div>
                <div class="flex-shrink-0">
                    <span class="pt-2 text-4xl font-bold text-gray-800 uppercase dark:text-gray-100">
                        $29.90
                    </span>
                    <span class="text-gray-500 dark:text-gray-400">
                        /month
                    </span>
                </div>
                <ul class="flex-1 space-y-4">
                    <li class="text-gray-500 dark:text-gray-400">
                        Up to 8000 tokens per day
                    </li>
                    <li class="text-gray-500 dark:text-gray-400">
                        unlimited projects
                    </li>
                    <li class="text-gray-500 dark:text-gray-400">
                        Up to 50 session
                    </li>
                </ul>

            <button @onclick="() => InvokeAppropriateAction(8000)"
                    class="@(wallet.SubscriptionTier == 2 ? "bg-gray-400 cursor-not-allowed" : "bg-green-600 hover:bg-green-700") inline-flex items-center justify-center px-4 py-2 font-semibold text-white uppercase transition-colors rounded-lg focus:outline-none">
                                @(wallet.SubscriptionTier == 2 ? "Current Plan" : (wallet.SubscriptionTier > 0 ? "Change Plan" : "Start Subscription"))
            </button>
            </div>
        </div>
    </div>

    <div class="container px-6 py-8 mx-auto">
        <div class="flex flex-col items-center justify-center space-y-8 lg:-mx-4 lg:flex-row lg:items-stretch lg:space-y-0">
            <div class="flex flex-col w-full max-w-sm p-8 space-y-8 text-center bg-white border-2 border-gray-200 rounded-lg lg:mx-4 dark:!bg-gray-800 dark:border-gray-700">
                <div class="flex-shrink-0">
                    <span class="pt-2 text-4xl font-bold text-gray-800 uppercase dark:text-gray-100">
                        24000 Tokens
                    </span>
                    <span class="text-gray-500 dark:text-gray-400">
                        for $5.99
                    </span>
                </div>
                <button @onclick="() => PurchaseTokens(24000)" class="inline-flex items-center justify-center px-4 py-2 font-semibold text-white uppercase transition-colors bg-green-600 rounded-lg hover:bg-green-700 focus:outline-none">
                    Buy Now
                </button>
            </div>

            <div class="flex flex-col w-full max-w-sm p-8 space-y-8 text-center bg-white border-2 border-gray-200 rounded-lg lg:mx-4 dark:!bg-gray-800 dark:border-gray-700">
                <div class="flex-shrink-0">
                    <span class="pt-2 text-4xl font-bold text-gray-800 uppercase dark:text-gray-100">
                        40000 Tokens
                    </span>
                    <span class="text-gray-500 dark:text-gray-400">
                        for $9,99
                    </span>
                </div>
                <button @onclick="() => PurchaseTokens(40000)" class="inline-flex items-center justify-center px-4 py-2 font-semibold text-white uppercase transition-colors bg-green-600 rounded-lg hover:bg-green-700 focus:outline-none">
                    Buy Now
                </button>
            </div>

            <div class="flex flex-col w-full max-w-sm p-8 space-y-8 text-center bg-white border-2 border-gray-200 rounded-lg lg:mx-4 dark:!bg-gray-800 dark:border-gray-700">
                <div class="flex-shrink-0">
                    <span class="pt-2 text-4xl font-bold text-gray-800 uppercase dark:text-gray-100">
                        80000 Tokens
                    </span>
                    <span class="text-gray-500 dark:text-gray-400">
                        for $19,99
                    </span>
                </div>
                <button @onclick="() => PurchaseTokens(80000)" class="inline-flex items-center justify-center px-4 py-2 font-semibold text-white uppercase transition-colors bg-green-600 rounded-lg hover:bg-green-700 focus:outline-none">
                    Buy Now
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .flex-shrink-0 {
        position: static !important;
        height: auto !important;
    }

    h2 {
        font-size: 1.5rem !important;
    }
</style>

@code {
    [CascadingParameter(Name = "Wallet")]
    public Wallet wallet { get; set; }

    private async Task InvokeAppropriateAction(int tokenAmount)
    {
        if (wallet.SubscriptionTier == 0)
        {
            await SubscribeTokens(tokenAmount);
        }
        else if (wallet.SubscriptionTier > 0)
        {
            await UpdateSubscription(tokenAmount);
        }
        // No else case needed, as the button should be disabled for the current plan, preventing this method from being called.
    }

    private async Task PurchaseTokens(int tokenAmount)
    {
        try
        {
            var response = await Http.PostAsJsonAsync<int>("Stripe/create-payment-session", tokenAmount);
            if (response.IsSuccessStatusCode)
            {
                var sessionData = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                NavMan.NavigateTo(sessionData["url"]);
            }
            else
            {
                // Handle errors (e.g., display a message to the user)
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error during PurchaseTokens: " + ex.Message);
        }
    }

    private async Task SubscribeTokens(int tokenAmount)
    {
        try
        {
            var response = await Http.PostAsJsonAsync<int>("Stripe/create-subscription-session", tokenAmount);
            if (response.IsSuccessStatusCode)
            {
                var sessionData = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                NavMan.NavigateTo(sessionData["url"]);
            }
            else
            {
                // Handle errors
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error during SubscribeTokens: " + ex.Message);
        }
    }

    private async Task UpdateSubscription(int newTokenAmount)
    {
        // Determine NewPriceId based on newTokenAmount
        string newPriceId = newTokenAmount switch
        {
            2000 => "price_1ObX2bGS8y7NleDORuIlzPCO",
            8000 => "price_1ObX2bGS8y7NleDOvy9Btv2z",
            _ => null
        };

        // Ensure there is a valid price ID before proceeding
        if (newPriceId == null)
        {
            Console.WriteLine("Invalid token amount specified.");
            return;
        }

        var requestData = new
        {
            SubscriptionId = wallet.StripeSubscriptionId, // Assuming 'wallet' is defined elsewhere in your code
            NewPriceId = newPriceId
        };

        try
        {
            // Assuming 'Http' is an instance of HttpClient defined elsewhere in your code
            var response = await Http.PostAsJsonAsync("Stripe/update-subscription", requestData);
            if (response.IsSuccessStatusCode)
            {
                // Assuming you want to navigate to a URL returned in the response
                var sessionData = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                NavMan.NavigateTo("/home");
            }
            else
            {
                Console.WriteLine($"Failed to update subscription: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during UpdateSubscription: {ex.Message}");
        }
    }

    private async Task CancelSubscription()
    {
        var requestData = new
        {
            SubscriptionId = wallet.StripeSubscriptionId,
            InvoiceNow = false,  // Assuming default value
            Prorate = true       // Assuming default value
        };

        try
        {
            var response = await Http.PostAsJsonAsync("Stripe/cancel-subscription", requestData);
            if (response.IsSuccessStatusCode)
            {
                NavMan.NavigateTo("/home");
            }
            else
            {
                // Log or handle the error response for debugging
                var errorResponse = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Failed to cancel subscription: {errorResponse}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error during CancelSubscription: " + ex.Message);
        }
    }
}

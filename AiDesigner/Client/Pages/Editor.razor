@page "/editor"
@inject IJSRuntime JSRuntime
@using Newtonsoft.Json;
@using Newtonsoft.Json.Serialization;
@using NodeBaseApi.Version2
@using Microsoft.AspNetCore.Authorization
@using System.Text;
@inject HttpClient Http
@attribute [Authorize]
@using AiDesigner.Client.Modals
@using AiDesigner.Client.Components
@using System.Reflection;
@using System.Collections;
@using System.Runtime.Serialization.Formatters.Binary;
@using System.IO;
@using AiDesigner.Shared.Data;
@using System.Diagnostics;

@if (localProgram != null)
{
    <AiDesigner.Client.Modals.ExacuteProgramNobtn @ref="epnb" AP="localProgram"></AiDesigner.Client.Modals.ExacuteProgramNobtn>
    <AddInput @ref="api" OnNewOutputCreated="AddProgramInput" />
    <AddOutput @ref="apo" OnNewOutputCreated="AddProgramOutput" />

@*    <BlockSelector SendBack="HandleButtonSelection" />*@
}

<div class="editor-layout dark:bg-gray-800">
    <!-- Navbar -->
    <div class="navbar bg-gray-500 dark:bg-gray-700 text-white px-5 py-2 border-gray-300 dark:border-gray-600">
        <div class="flex justify-between items-center">
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="SaveProgram">Save</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="ExecuteProgram">Execute</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="BuildProgram">Build</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="UndoAction">Undo</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="RedoAction">Redo</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="ZoomIn">+</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="ZoomOut">-</button>
@*            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="CopyBlock">Copy</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="CutBlock">Cut</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="PasteBlock">Paste</button>*@
            <a class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" href="path/to/your/docs">Help</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content flex flex-grow">
        <div id="left-side" class="resizable-x left-side bg-gray-200 dark:bg-gray-700 overflow-auto" style="width: 16.666667%;">
            <div class="config-box p-0 border-gray-300 dark:border-gray-600">
                <!-- Program configs -->
            </div>
            <div class="variable-list p-4">
                <!-- A list of the variables -->
            </div>
        </div>

        <div id="middle-content" class="middle-content flex-grow bg-white dark:bg-gray-900 p-0 overflow-auto">
            <div id="whiteboard-content" class="bg-gray-500 dark:bg-gray-500 text-white py-3" style="width: 100%;
        height: 100%;">
                <div id="whiteboard" class="whiteboard" @oncontextmenu="ShowContextMenu">
                    <div id="canvas" class="canvas">
                        <div id="connection-layer" style="position: relative; z-index: 22; ">
                        </div>
                        @if(_localProgram is CustomProgram customProgram)
                        {
                            <div id="Input" class="node" style="left: @(customProgram.ProgramStructure.ProgramStartLocation.Item1.ToString()+"px"); top: @(customProgram.ProgramStructure.ProgramStartLocation.Item2.ToString()+"px");">
                                <div class="top-part dark:bg-gray-800">
                                                                        <span style="margin-left: 10px;">Input</span>
                                </div>
                                <div class="main-part dark:bg-gray-700">
                                    <div class="left-part">
                                         <!--Left side content-->
                                    </div>
                                    <div class="right-part">
                                        @foreach (var output in customProgram.ProgramStructure.ProgramStart)
                                        {
                                            <!--make a componenet  or something so it show the right input / output type-->
                                            <div class="node-output d-flex ">
                                                <span class="small-font">@output.Name</span>
                                                <div id="@output.Id" class="@GetShape(output.Type.ToString()) @GetColor(output.Type.ToString()) Connection" @onclick="() => SelectOutput(output)"></div>
                                            </div>
                                        }
                                        @if (customProgram.ProgramStructure.ProgramStart.Count() == 0)
                                        {
                                            <hr style="border-top: none; height: 10px; background-color: transparent;" />
                                        }
                                        <button @onclick="Openapi" class="btn btn-primary px-0 py-0 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                                Create input
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div id="Output" class="node" style="left: @(customProgram.ProgramStructure.ProgramEndLocation.Item1.ToString()+"px"); top: @(customProgram.ProgramStructure.ProgramEndLocation.Item2.ToString()+"px");">
                                <div class="top-part dark:bg-gray-800">
                                        <span style="margin-left: 10px;">Output</span>
                                </div>
                                <div class="main-part dark:bg-gray-700">
                                    <div class="left-part">
                                        @foreach (var input in customProgram.ProgramStructure.ProgramEnd)
                                        {
                                            <!--make a componenet  or something so it show the right input / output type-->
                                            <div class="node-input d-flex ">
                                                <div id="@input.Id" class="@GetShape(input.Type.ToString()) @GetColor(input.Type.ToString()) Connection" @onclick="() => TryConnect(input)"></div>
                                                <span class="small-font">@input.Name</span>
                                            </div>
                                        }
                                        @if (customProgram.ProgramStructure.ProgramStart.Count() == 0)
                                        {
                                            <hr style="border-top: none; height: 10px; background-color: transparent;" />
                                        }
                                        <button @onclick="Openapo" class="btn btn-primary px-0 py-0 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                            Create output
                                        </button>
                                    </div>
                                    <div class="right-part">
                                        <!--Right side content-->
                                    </div>
                                </div>
                            </div>
                            @foreach (var node in customProgram.ProgramStructure.ProgramBlocks)
                            {
                                <div id="@node.Id" class="node" style="left: @(node.X.ToString() + "px"); top: @(node.Y.ToString() + "px");" @onclick="(() => SelectNode(node))">
                                    <div class="top-part dark:bg-gray-800">
                                        <span style="margin-left: 10px;">@node.Block.Name</span>
                                    </div>
                                    <div class="main-part dark:bg-gray-700">
                                        <div class="left-part">
                                            <!-- Left part content goes here -->
                                            @foreach (var input in node.Block.Inputs)
                                            {
                                                <div class="node-input d-flex ">
                                                    <div id="@input.Id" class="@GetShape(input.Type.ToString()) @GetColor(input.Type.ToString()) Connection" @onclick="() => TryConnect(input)"></div>
                                                    <span class="small-font">@input.Name</span>
                                                </div>
                                            }
                                        </div>
                                        <div class="right-part">
                                            <!-- Right part content goes here -->
                                            @foreach (var output in node.Block.Outputs)
                                            {
                                                <div class="node-output d-flex ">
                                                    <span class="small-font">@output.Name</span>
                                                    <div id="@output.Id" class="@GetShape(output.Type.ToString()) @GetColor(output.Type.ToString()) Connection" @onclick="() => SelectOutput(output)"></div>
                                                </div>

                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }

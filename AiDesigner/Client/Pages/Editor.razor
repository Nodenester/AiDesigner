    private async Task DrawConnections(ProgramStructure programStructure)
    {
        foreach (var block in programStructure.ProgramBlocks)
        {
            // Draw connections for block inputs
            if (block.Inputs != null)
            {
                for (int i = 0; i < block.Inputs.Count; i++)
                {
                    var output = block.Inputs[i];
                    var input = block.Block.Inputs[i];

                    if (output != null && input != null && output.ToString() != "00000000-0000-0000-0000-000000000000")
                    {
                        //Console.WriteLine("---------------------");
                        //Console.WriteLine($"Index: {i}, Value: {output}");
                        //Console.WriteLine($"Index: {i}, Value: {input.Id}");
                        //Console.WriteLine("---------------------");

                        await JSRuntime.InvokeVoidAsync("jsPlumbInterop.connectInputs", output, input.Id, GetLineColor(input.Type.ToString()));
                    }
                }
            }
        }

        //Connects the end plss
        foreach (var input in programStructure.ProgramEnd)
        {
            if (programStructure.ProgramEndConnections.TryGetValue(input.Id, out Guid outputId))
            {
                //Console.WriteLine("---------------------");
                //Console.WriteLine($"Input Id: {input.Id}");
                //Console.WriteLine($"Connected Output Id: {outputId}");
                //Console.WriteLine("---------------------");

                await JSRuntime.InvokeVoidAsync("jsPlumbInterop.connectInputs", outputId, input.Id, GetLineColor(input.Type.ToString()));
            }
        }
    }


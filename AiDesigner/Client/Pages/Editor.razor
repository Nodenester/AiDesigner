    public void SelectCustomBlock(ProgramBlock programBlock, string customBlockId)
    {
        var customBlockProgram = EAPs.OfType<CustomBlockProgram>().FirstOrDefault(eap => eap.Id.ToString() == customBlockId);
        if (customBlockProgram != null)
        {
            programBlock.Block.Inputs = customBlockProgram.ProgramStructure.ProgramStart.Select(output => ConvertOutputToInput(output)).ToList();
            programBlock.Block.Inputs.ForEach(input =>
            {
                localProgram.ProgramStructure.RemoveConnection(input.Id);
                input.Id = Guid.NewGuid();
            });

            // Processing Outputs
            programBlock.Block.Outputs = customBlockProgram.ProgramStructure.ProgramEnd.Select(input => ConvertInputToOutput(input)).ToList();
            programBlock.Outputs = programBlock.Block.Outputs.Select(output =>
            {
                localProgram.ProgramStructure.RemoveConnection(output.Id);
                return Guid.NewGuid();
            }).ToList();

            programBlock.VariableId = Guid.Parse(customBlockId);
            Guid customBlockGuid = Guid.Parse(customBlockId);
            if (localProgram.ProgramStructure.CustomPrograms.ContainsKey(programBlock.Id))
            {
                localProgram.ProgramStructure.CustomPrograms[programBlock.Id] = new CustomBlockProgram { Name = customBlockProgram.Name, Id = Guid.Parse(customBlockId) };
            }
            else
            {
                localProgram.ProgramStructure.CustomPrograms.Add(programBlock.Id, new CustomBlockProgram { Name = customBlockProgram.Name, Id = Guid.Parse(customBlockId) });
            }
        }
    }


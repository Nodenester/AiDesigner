@page "/editor"
@inject IJSRuntime JSRuntime
@using Newtonsoft.Json;
@using Newtonsoft.Json.Linq
@using Newtonsoft.Json.Serialization;
@using NodeBaseApi.Version2
@using Microsoft.AspNetCore.Authorization
@using System.Text;
@inject HttpClient Http
@attribute [Authorize]
@using AiDesigner.Client.Modals
@using AiDesigner.Client.Components
@using System.Reflection;
@using System.Collections;
@using System.Runtime.Serialization.Formatters.Binary;
@using System.IO;
@using AiDesigner.Shared.Data;
@using System.Diagnostics;
@using AiDesigner.Client.Components.Chat;
@using AiDesigner.Client.Components.EditorLibrary
@using static AiDesigner.Client.Components.Chat.InputList
@inject TooltipService tooltipService
@inject NavigationManager MyNavigationManager

@if (localProgram != null)
{
    <AiDesigner.Client.Modals.ExacuteProgramNobtn @ref="epnb" AP="localProgram"></AiDesigner.Client.Modals.ExacuteProgramNobtn>
    <AddInput @ref="api" OnNewOutputCreated="AddProgramInput" />
    <AddOutput @ref="apo" OnNewOutputCreated="AddProgramOutput" />
    <AddVariable @ref="apv" OnNewOutputCreated="AddProgramVariable" />
@*    <BlockSelector SendBack="HandleButtonSelection" />*@
}

<div class="editor-layout dark:bg-gray-800">
    <!-- Navbar -->
    <div class="navbar bg-gray-500 dark:bg-gray-700 text-white px-5 py-2 border-gray-300 dark:border-gray-600">
        <div class="flex justify-between items-center">
            <button class="mx-1 py-1 px-2 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none @(Saving ? "bg-gray-500" : Saved ? "bg-green-600" : "bg-gray-500") hover:bg-gray-700"
                    @onclick="SaveProgram"
                    disabled="@(Saving || Saved)">
                @if (Saving)
                {
                    <span><i class="fas fa-spinner fa-spin"></i></span> <!-- Loading symbol -->
                }
                else if (Saved)
                {
                    <span><i class="fas fa-check"></i></span> <!-- Checkmark symbol -->
                }
                else
                {
                    <span>Save</span>
                }
            </button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="ExecuteProgram">Execute</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="BuildProgram">Build</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="UndoAction">Undo</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="RedoAction">Redo</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="ZoomIn">+</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="ZoomOut">-</button>
@*            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="CopyBlock">Copy</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="CutBlock">Cut</button>
            <button class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" @onclick="PasteBlock">Paste</button>*@
            <a class="mx-1 py-1 px-2 bg-gray-500 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg shadow-md focus:outline-none" href="/documentation/help/troubleshooting">Help</a>
@*             <div class="w-full content-end py-1">
                <input type="number"
                       class="w-10 p-1 border rounded dark:bg-gray-600 dark:text-white outline-none border-0"
                       min="1"
                       max="25"
                       value="5"
                @onchange="(ChangeEventArgs e) => SetGridSize(e)" />
            </div> *@
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content flex flex-grow">
        <div id="left-side" class="resizable-x left-side bg-gray-200 dark:bg-gray-700 overflow-auto" style="width: 16.666667%; max-height: 78.4vh;">
            <div class="config-box p-0 border-b border-gray-300 dark:border-gray-600" style="overflow-y: auto;">
                <!-- Program configs -->
                <p class="dark:bg-gray-700 border-gray-700 w-full align-top px-1">Settings</p>
                @if(localProgram != null)
                {
                <div class="flex justify-center">
                    <div class="@((localProgram is CustomProgram) ? "w-1/2" : "w-2/5") p-4 rounded-lg bg-gray-100 dark:bg-gray-700 mx-2 w-full">
                            <div class="mt-1">
                            <label for="name" class="block text-sm font-medium text-gray-700 dark:text-white">Name</label>
                            <input @bind="localProgram.Name" type="text" id="name" class="w-full p-2 border rounded dark:bg-gray-600 dark:text-white outline-none border-0 outline-none" placeholder="Name" />
                        </div>
                        <div class="mt-1">
                            <label for="description" class="block text-sm font-medium text-gray-700 dark:text-white">Description</label>
                            <textarea @bind="localProgram.Description" id="description" class="w-full p-2 border rounded dark:bg-gray-600 dark:text-white outline-none border-0 outline-none" placeholder="Description"></textarea>
                        </div>
                        <div class="mt-1">
                            <label for="IsPublic" class="block text-sm font-medium text-gray-700 dark:text-white">Is public</label>
                            <div class="mt-1">
                                    <input type="checkbox" @bind="localProgram.IsPublic" id="IsPublic" class="w-4 h-4 accent-green-600 rounded" />
                                <label for="IsPublic" class="ml-2 text-sm text-gray-700 dark:text-white">Enabled</label>
                            </div>
                        </div>
                        @if (localProgram is CustomProgram)
                        {
                            <label for="SupportsSessions" class="block text-sm font-medium text-gray-700 dark:text-white">Supports sessions</label>
                            <div class="mt-1">
                                    <input type="checkbox" @bind="localProgram.SupportsSessions" id="SuportSession" class="w-4 h-4 accent-green-600 rounded" />
                                <label for="SuportSession" class="ml-2 text-sm text-gray-700 dark:text-white">Enabled</label>
                            </div>
                            <label for="SupportsChat" class="block text-sm font-medium text-gray-700 dark:text-white">Supports chat</label>
                                <div class="mt-1">
                                    <input type="checkbox"
                                           checked="@localProgram.SupportsChat"
                                           @onchange="HandleChange"
                                           id="SupportsChat"
                                           class="w-4 h-4 accent-green-600 rounded" />
                                    <label for="SupportsChat" class="ml-2 text-sm text-gray-700 dark:text-white">Enabled</label>
                                </div>

                            <div class="mt-1">
                                <label for="apiKey" class="block text-sm font-medium text-gray-700 dark:text-white">API Key</label>
                                <input type="text" @bind="((CustomProgram)localProgram).ApiKey" id="apiKey" class="w-full p-2 border rounded dark:bg-gray-600 dark:text-gray-300 outline-none border-0" readonly />
                            </div>
                        }
                    </div>
                </div>
                }
            </div>
            <div class="variable-list p-0 border-b border-gray-300 dark:border-gray-600" style="overflow-y: auto;">
                <!-- The Variables -->
                <div class="flex justify-between items-center px-1 dark:bg-gray-700 border-gray-700 w-full align-top">
                    <p>Variables</p>
                    @if (localProgram != null)
                    {
                        <button @onclick="Openapv" class="dark:bg-gray-700 dark:text-white dark:hover:bg-gray-600 px-4 rounded text-2xl">+</button>
                    }
                </div>
                @if (localProgram != null)
                {
                    @foreach (var Variable in localProgram.ProgramStructure.Variables)
                    {
                        <div class="mx-8 relative button-hover">
                            <!-- Add the hover class here -->
                            <!-- Main Button -->
                            <button @onclick="() => SelectVariable(Variable.Value)" class="dark:bg-gray-700 dark:text-white dark:hover:bg-gray-600 py-2 rounded w-full flex justify-between items-center border-b border-gray-600">
                                <span class="overflow-hidden ml-2 text-start w-50 text-lg">@Variable.Value.Name</span>
                                <div class="flex overflow-hidden items-end mr-1 w-50">
                                    @if (Variable.Value.IsList)
                                    {
                                        <p>List of: </p>
                                    }
                                    <p>@Variable.Value.Type</p>
                                </div>

                                <!-- Remove Button - Initially Hidden, Shown on Hover -->
                                <button @onclick="() => RemoveVariable(Variable.Key)"
                                class="absolute top-0 right-0 p-0 m-1 text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white close-button">
                                    X
                                </button>
                            </button>
                        </div>
                    }
                }
            </div>
        </div>

        <div id="middle-content" class="middle-content flex-grow bg-white dark:bg-gray-900 p-0 overflow-auto">
            <div id="whiteboard-content" class="bg-gray-500 dark:bg-gray-500 text-white py-3" style="width: 100%; height: 100%;">
                <div id="whiteboard" class="whiteboard" @oncontextmenu="ShowContextMenu">
                    <div id="canvas" class="canvas">
                        <div id="connection-layer" style="position: relative; z-index: 22; ">
                        </div>
                        @if (localProgram != null)
                        {
                            <div id="Input" class="node" style="left: @(localProgram.ProgramStructure.ProgramStartLocation.Item1.ToString()+"px"); top: @(localProgram.ProgramStructure.ProgramStartLocation.Item2.ToString()+"px");">
                                <div class="top-part dark:bg-gray-600">
                                    <span style="margin-left: 10px;">Input</span>
                                </div>
                                <div class="main-part dark:bg-gray-700">
                                    <div class="left-part">
                                         <!--Left side content-->
                                    </div>
                                    <div class="right-part">
                                        @foreach (var output in localProgram.ProgramStructure.ProgramStart.Select((value, index) => new { Value = value, Index = index }))
                                        {
                                            if (output.Value.Name == "Chat History")
                                            {
                                                if (localProgram.SupportsChat)
                                                {
                                                    <div class="node-output d-flex"
                                                    @onmouseenter='() => ShowTooltip(inputElementReferences.TryGetValue(output.Value.Id.ToString(), out var elementRef) ? elementRef : new ElementReference(), null, output.Value)'>
                                                        <span class="small-font">
                                                            @output.Value.Name
                                                        </span>
                                                        <div id="@output.Value.Id" class="@GetShape(output.Value.Type.ToString(), output.Value.IsList) @GetColor(output.Value.Type.ToString()) Connection" @onclick="() => SelectOutput(output.Value)"></div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="node-output d-flex"
                                                @onmouseenter='() => ShowTooltip(inputElementReferences.TryGetValue(output.Value.Id.ToString(), out var elementRef) ? elementRef : new ElementReference(), null, output.Value)'>
                                                    <span class="small-font">
                                                        @output.Value.Name
                                                        @if (output.Index > 1)
                                                        {
                                                            <text>&#8203;</text>
                                                        }
                                                    </span>
                                                    <div id="@output.Value.Id" class="@GetShape(output.Value.Type.ToString(), output.Value.IsList) @GetColor(output.Value.Type.ToString()) Connection" @onclick="() => SelectOutput(output.Value)"></div>
                                                </div>
                                            }
                                        }
                                        @if (localProgram.ProgramStructure.ProgramStart.Count() == 0)
                                        {
                                            <hr style="border-top: none; height: 10px; background-color: transparent;" />
                                        }
                                        <div class="node-output d-flex">
                                            <button @onclick="Openapi" class="px-1 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                                Add input
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div id="Output" class="node" style="left: @(localProgram.ProgramStructure.ProgramEndLocation.Item1.ToString()+"px"); top: @(localProgram.ProgramStructure.ProgramEndLocation.Item2.ToString()+"px");">
                                <div class="top-part dark:bg-gray-600">
                                        <span style="margin-left: 10px;">Output</span>
                                </div>
                                <div class="main-part dark:bg-gray-700">
                                    <div class="left-part">
                                        @foreach (var input in localProgram.ProgramStructure.ProgramEnd.Select((value, index) => new { Value = value, Index = index }))
                                        {
                                            <div class="node-input d-flex"
                                                @onmouseenter='() => ShowTooltip(inputElementReferences.TryGetValue(input.Value.Id.ToString(), out var elementRef) ? elementRef : new ElementReference(), input.Value )'>
                                                <div id="@input.Value.Id" class="@GetShape(input.Value.Type.ToString(), input.Value.IsList) @GetColor(input.Value.Type.ToString()) Connection" @onclick="() => TryConnect(input.Value)"></div>
                                                <span class="small-font">
                                                    @input.Value.Name
                                                    @if (input.Index != 0) 
                                                    {
                                                        <text>&#8203;</text>
                                                    }
                                                </span>
                                            </div>
                                        }
                                        @if (localProgram.ProgramStructure.ProgramEnd.Count() == 0)
                                        {
                                            <hr style="border-top: none; height: 10px; background-color: transparent;" />
                                        }
                                        <button @onclick="Openapo" class="px-1 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                            Add output
                                        </button>
                                    </div>
                                    <div class="right-part">
                                        <!--Right side content-->
                                    </div>
                                </div>
                            </div>
                            @foreach (var node in localProgram.ProgramStructure.ProgramBlocks)
                            {
                                <div id="@node.Id" class="node" style="left: @(node.X.ToString().Replace("−", "-") + "px"); top: @(node.Y.ToString().Replace("−", "-") + "px");" @onclick="(() => SelectNode(node))">
                                    <div class="top-part dark:bg-gray-600">
                                        <div style="display: inline-block; margin-left: 10px;" class="w-full">
                                            <span>@node.Block.Name</span>
                                            @if (node.Block.Name == "Get Variable")
                                            {
                                                <div style="width: calc(100%); margin-left: -0.6rem; padding-right: 0.02rem;">
                                                    <select @bind-value="node.VariableId" @bind-value:event="oninput" @onchange="((ChangeEventArgs e) => UpdateType(node, localProgram.ProgramStructure.Variables[node.VariableId].Type, -1, 0, localProgram.ProgramStructure.Variables[node.VariableId].IsList))" class="w-full p-2 border dark:bg-gray-700 dark:text-white outline-none border-0">
                                                        <option value="@Guid.Empty"disabled selected hidden>Select Variable</option>
                                                        @foreach (var Variable in localProgram.ProgramStructure.Variables)
                                                        {
                                                            <option value="@Variable.Value.Id">@Variable.Value.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            @if (node.Block.Name == "Set Variable")
                                            {
                                                <div style="width: calc(100%); margin-left: -0.6rem; padding-right: 0.02rem;">
                                                    <select @bind-value="node.VariableId" @bind-value:event="oninput" @onchange="((ChangeEventArgs e) => UpdateType(node, localProgram.ProgramStructure.Variables[node.VariableId].Type, 1, -1, localProgram.ProgramStructure.Variables[node.VariableId].IsList))" class="w-full p-2 border dark:bg-gray-700 dark:text-white outline-none border-0">
                                                        <option value="@Guid.Empty" disabled selected hidden>Select Variable</option>
                                                        @foreach (var Variable in localProgram.ProgramStructure.Variables)
                                                        {
                                                            <option value="@Variable.Value.Id">@Variable.Value.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            @if (node.Block.Name == "For Loop")
                                            {
                                                <div style="width: calc(100%); margin-left: -0.6rem; padding-right: 0.02rem;">
                                                    @if (node.Block.Outputs[1].Type != null)
                                                    {
                                                        <select @bind-value="node.Block.Outputs[1].Type" @bind-value:event="oninput" @onchange="((ChangeEventArgs e) => UpdateType(node, e.Value))" class="w-full p-2 border dark:bg-gray-700 dark:text-white outline-none border-0">
                                                            <option value="String">String</option>
                                                            <option value="Picture">Picture</option>
                                                            <option value="Number">Number</option>
                                                            <option value="Boolean">Boolean</option>
                                                            <option value="Audio">Audio</option>
                                                            <option value="Object">Object</option>
                                                        </select>
                                                    }
                                                </div>
                                            }
                                            @if (node.Block.Name == "Set Item" || node.Block.Name == "Get Item" || node.Block.Name == "Add Item" || node.Block.Name == "Remove Item" || node.Block.Name == "Find Item")
                                            {
                                                <div style="width: calc(100%); margin-left: -0.6rem; padding-right: 0.02rem;">
                                                    <select @bind-value="node.Block.Inputs[0].Type" @bind-value:event="oninput" @onchange="((ChangeEventArgs e) => UpdateBlockType(node, e.Value))" class="w-full p-2 border dark:bg-gray-700 dark:text-white outline-none border-0">
                                                        <option value="String">String</option>
                                                        <option value="Picture">Picture</option>
                                                        <option value="Number">Number</option>
                                                        <option value="Boolean">Boolean</option>
                                                        <option value="Audio">Audio</option>
                                                        <option value="Object">Object</option>
                                                    </select>
                                                </div>
                                            }
                                            @if (node.Block.Name == "Select")
                                            {
                                                <div style="width: calc(100%); margin-left: -0.6rem; padding-right: 0.02rem;">
                                                    <select @bind-value="node.Block.Inputs[1].Type" @bind-value:event="oninput" @onchange="((ChangeEventArgs e) => UpdateBlockType(node, e.Value))" class="w-full p-2 border dark:bg-gray-700 dark:text-white outline-none border-0">
                                                        <option value="String">String</option>
                                                        <option value="Picture">Picture</option>
                                                        <option value="Number">Number</option>
                                                        <option value="Boolean">Boolean</option>
                                                        <option value="Audio">Audio</option>
                                                        <option value="Object">Object</option>
                                                    </select>
                                                </div>
                                            }
                                            @if (node.Block.Name == "Custom Block")
                                            {
                                                <div style="width: calc(100%); margin-left: -0.6rem; padding-right: 0.03rem;">
                                                    @if (localProgram != null && localProgram.ProgramStructure.CustomPrograms.ContainsKey(node.Id))
                                                    {
                                                        <select @bind-value="localProgram.ProgramStructure.CustomPrograms[node.Id].Id"
                                                                @bind-value:event="oninput"
                                                                @onchange="((ChangeEventArgs e) => SelectCustomBlock(node, e.Value.ToString()))"
                                                                class="w-full p-2 border dark:bg-gray-700 dark:text-white outline-none border-0">
                                                            <option value="@Guid.Empty" disabled selected hidden>Select block</option>
                                                            @foreach (var CustomBlock in EAPs.Where(eap => eap is CustomBlockProgram))
                                                            {
                                                                <option value="@CustomBlock.Id">@CustomBlock.Name</option>
                                                            }
                                                            @foreach (WorkshopArticle WorkshopCustomBlock in workshopArticles.Where(wcb => wcb.Type == "CustomBlock"))
                                                            {
                                                                <option value="@WorkshopCustomBlock.ProgramId">@WorkshopCustomBlock.Name.</option>
                                                            }

                                                        </select>
                                                    }
                                                    else if (localProgram != null)
                                                    {
                                                        <select @onchange="((ChangeEventArgs e) => SelectCustomBlock(node, e.Value.ToString()))"
                                                                class="w-full p-2 border dark:bg-gray-700 dark:text-white outline-none border-0">
                                                            <option value="@Guid.Empty" disabled selected hidden>Select block</option>
                                                            @foreach (var CustomBlock in EAPs.Where(eap => eap is CustomBlockProgram))
                                                            {
                                                                <option value="@CustomBlock.Id">@CustomBlock.Name</option>
                                                            }
                                                        </select>
                                                    }
                                                </div>
                                            }
                                            @if (node.Block.Name == "GPT Block")
                                            {
                                                if(node != null)
                                                {
                                                <div style="width: calc(100%); margin-left: -0.6rem; padding-right: 0.02rem;">
                                                    <select @bind-value="node.VariableId" @bind-value:event="oninput" class="w-full p-2 border dark:bg-gray-700 dark:text-white outline-none border-0">
                                                        <option value="00000000-0000-0000-0000-000000000000">Default Model</option>
                                                        <option value="10000000-0000-0000-0000-000000000000">ChatGPT Turbo</option>
                                                        <option value="20000000-0000-0000-0000-000000000000">Davinci Text</option>
                                                        <option value="30000000-0000-0000-0000-000000000000">Davinci Code</option>
                                                        <option value="40000000-0000-0000-0000-000000000000">GPT4</option>
                                                        <option value="50000000-0000-0000-0000-000000000000">GPT4 32k Context</option>
                                                        <option value="60000000-0000-0000-0000-000000000000">Ada Text</option>
                                                        <option value="70000000-0000-0000-0000-000000000000">Ada Text Embedding</option>
                                                        <option value="80000000-0000-0000-0000-000000000000">Babbage Text</option>
                                                        <option value="90000000-0000-0000-0000-000000000000">Text Moderation Latest</option>
                                                    </select>
                                                </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <div class="main-part dark:bg-gray-700">
                                        <div class="left-part">
                                            <!-- Left part content goes here -->
                                            @foreach (var input in node.Block.Inputs)
                                            {
                                                <div class="node-input d-flex"
                                                     @ref="inputElementReferences[input.Id.ToString()]"
                                                     @onmouseenter='() => ShowTooltip(inputElementReferences.TryGetValue(input.Id.ToString(), out var elementRef) ? elementRef : new ElementReference(), input)'
                                                     @onmouseleave="HideTooltip">
                                                    <div id="@input.Id"
                                                         class="@GetShape(input.Type.ToString(), input.IsList) @GetColor(input.Type.ToString()) Connection"
                                                         @onclick="() => TryConnect(input)">
                                                    </div>
                                                    @if (input.Name.Contains(" &#8203;"))
                                                    {
                                                        <span class="small-font">@input.Name.Replace(" &#8203;", "\u200B")</span>
                                                    }
                                                    else{
                                                        <span class="small-font">@input.Name</span>
                                                    }
                                                </div>
                                            }
                                            @if (node.Block.Name == "Select")
                                            {
                                                <button @onclick='() => AddSelectInput(node, "Input for case")' class="px-1 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                                    Add input
                                                </button>
                                            }
                                            @if (node.Block.Name == "Concatenation")
                                            {
                                                <button @onclick='() => AddSelectInput(node, "String" )' class="px-1 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                                    Add input
                                                </button>
                                            }
                                            @if (node.Block.Name == "And Block")
                                            {
                                                <button @onclick='() => AddSelectInput(node, "Input")' class="px-1 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                                    Add input
                                                </button>
                                            }
                                            @if (node.Block.Name == "Combine Objects")
                                            {
                                                <button @onclick='() => AddSelectInput(node, "Object")' class="px-1 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                                    Add input
                                                </button>
                                            }
                                            @if (node.Block.Name == "Or Trigger")
                                            {
                                                <button @onclick='() => AddSelectInput(node, "Trigger")' class="px-1 text-sm small-font text-white bg-gray-600 hover:bg-gray-700 rounded-md d-flex" type="button">
                                                    Add input
                                                </button>
                                            }
                                            
                                        </div>
                                        <div class="right-part">
                                            <!-- Right part content goes here -->
                                            @foreach (var output in node.Block.Outputs)
                                            {
                                                <div class="node-output d-flex"
                                                     @ref="outputElementReferences[output.Id.ToString()]"
                                                     @onmouseenter='() => ShowTooltip(outputElementReferences.TryGetValue(output.Id.ToString(), out var elementRef) ? elementRef : new ElementReference(), null, output)'
                                                     @onmouseleave="HideTooltip">
                                                    <span class="small-font">@output.Name</span>
                                                    <div id="@output.Id"
                                                         class="@GetShape(output.Type.ToString(), output.IsList) @GetColor(output.Type.ToString()) Connection"
                                                         @onclick="() => SelectOutput(output)">
                                                    </div>
                                                </div>
                                            }

                                            <!--make a componenet  or something so it show the right input / output type-->
                                            <div class="node-input d-flex ">
                                                <div id="@input.Id" class="@GetShape(input.Type.ToString()) @GetColor(input.Type.ToString()) Connection" @onclick="() => TryConnect(input)"></div>
                                                <span class="small-font">@input.Name</span>
                                            </div>
                                        }
                                        @if (customBlockProgram.ProgramStructure.ProgramStart.Count() == 0)

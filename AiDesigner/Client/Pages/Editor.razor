    private void UpdateType(ProgramBlock node, object value, int Sidx = -1, int Eidx = -1, bool IsList = false)
    {
        string valueStr = value.ToString();
        if (Enum.IsDefined(typeof(NodeBaseApi.Version2.Type), valueStr))
        {
            NodeBaseApi.Version2.Type parsedType = (NodeBaseApi.Version2.Type)Enum.Parse(typeof(NodeBaseApi.Version2.Type), valueStr);
            if (Sidx != -1 && Eidx != -1)
            {
                node.Block.Outputs[Sidx].Type = parsedType;
                node.Block.Inputs[Eidx].Type = parsedType;
                node.Block.Inputs[Sidx].IsList = IsList;
                node.Block.Outputs[Eidx].IsList = IsList;
            }
            else if (Sidx == -1 && Eidx != -1)
            {
                node.Block.Outputs[Eidx].Type = parsedType;
                node.Block.Outputs[Eidx].IsList = IsList;
            }
            else if (Sidx != -1 && Eidx == -1)
            {
                node.Block.Inputs[Sidx].Type = parsedType;
                node.Block.Inputs[Sidx].IsList = IsList;
            }
            else
            {
                node.Block.Outputs[1].Type = parsedType;
                node.Block.Inputs[1].Type = parsedType;
            }
        }
        else
        {
            Console.WriteLine($"Invalid value: {valueStr}");
        }
    }

    private void UpdateBlockType(ProgramBlock node, object value)
    {
        if (!Enum.IsDefined(typeof(NodeBaseApi.Version2.Type), value.ToString()))
        {
            Console.WriteLine($"Invalid value: {value}");
            return;
        }

        NodeBaseApi.Version2.Type parsedType = (NodeBaseApi.Version2.Type)Enum.Parse(typeof(NodeBaseApi.Version2.Type), value.ToString());

        foreach (var input in node.Block.Inputs)
        {
            if (input.Type != NodeBaseApi.Version2.Type.Trigger && input.Name != "Index" && input.Name != "Selector")
            {
                input.Type = parsedType;
            }
        }

        foreach (var output in node.Block.Outputs)
        {
            if (output.Type != NodeBaseApi.Version2.Type.Trigger && output.Name != "Index")
            {
                output.Type = parsedType;
            }
        }
    }

    private void AddSwitchOutput(ProgramBlock node)
    {
        int idx = node.Block.Outputs.Count();
        node.Block.Outputs.Add(new Output
        {
            Name = $"Case &#8203; {idx}",
            Type = NodeBaseApi.Version2.Type.Trigger,
            Description = $"Triggered for case {idx}.",
        });
    }

    private void AddSelectInput(ProgramBlock node, string text)
    {
        int idx = node.Block.Inputs.Count();
        if (node.Block.Inputs.FirstOrDefault().Name.Split(' ')[0] == text.Split(' ')[0])
        {
            idx++;
        }

        node.Block.Inputs.Add(new Input
            {
                Id = Guid.NewGuid(),
                Name = $"{text.Split(' ')[0]} &#8203; {idx}",
                Type = node.Block.Inputs[1].Type,
                Description = $"{text} {idx}.",
            });
    }


        if (localProgram is CustomProgram customProgram)
        {
            if (customProgram.ProgramStructure.ProgramBlocks.Count() != 0)
            {
                var errors = CheckErrors(localProgram);

                if (errors.Count > 0)
                {
                    Errors = errors;
                }
                else
                {
                    await UpdateDb(localProgram);
                }
            }
            else
            {
                //Dont save if there are no blocks

            }
        }
        else if (localProgram is CustomBlockProgram customBlockProgram)
        {
            if (customBlockProgram.ProgramStructure.ProgramBlocks != null)
            {
                var errors = CheckErrors(localProgram);

                if (errors.Count > 0)
                {
                    Errors = errors;
                }
                else
                {
                    await UpdateDb(localProgram);
                }
            }
            else
            {
                //Dont save if there are no blocks
            }
        }
    }

    private async Task UndoAction()
    {
        if (_currentHistoryIndex > 0) // make sure we don't go past the start of the history
        {
            _currentHistoryIndex--;
            localProgram = Clone(History[_currentHistoryIndex]);
            APO = localProgram;
            await JSRuntime.InvokeVoidAsync("jsPlumbInterop.clearAllConnections");
            if (localProgram is CustomProgram customProgram)
            {
                DrawConnections(customProgram.ProgramStructure);
            }
            else if (localProgram is CustomBlockProgram customBlockProgram)
            {
                DrawConnections(customBlockProgram.ProgramStructure);
            }
        }
        Console.WriteLine("History index: " + _currentHistoryIndex);

        StateHasChanged();
    }

    private async Task RedoAction()
    {
        if (_currentHistoryIndex < History.Count - 1) // make sure we don't go past the end of the history
        {
            _currentHistoryIndex++;
            localProgram = Clone(History[_currentHistoryIndex]);
            APO = localProgram;
            await JSRuntime.InvokeVoidAsync("jsPlumbInterop.clearAllConnections");
            if (localProgram is CustomProgram customProgram)
            {
                DrawConnections(customProgram.ProgramStructure);
            }
            else if (localProgram is CustomBlockProgram customBlockProgram)
            {
                DrawConnections(customBlockProgram.ProgramStructure);
            }
        }
        Console.WriteLine("History index: " + _currentHistoryIndex);

        StateHasChanged();
    }


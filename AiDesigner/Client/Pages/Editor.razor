    public async Task RemovePort()
    {
        if (SelectedPort is Input input)
        {
            localProgram.ProgramStructure.RemoveConnection(input.Id);

            if (localProgram.ProgramStructure.ProgramEnd.Contains(input))
            {
                localProgram.ProgramStructure.ProgramEnd.Remove(input);
            }

            var blockContainingInput = localProgram.ProgramStructure.ProgramBlocks
                                       .FirstOrDefault(block => block.Block.Inputs.Contains(input));

            if (blockContainingInput != null)
            {
                blockContainingInput.Block.Inputs.Remove(input);
            }
        }
        else if (SelectedPort is Output output)
        {
            localProgram.ProgramStructure.RemoveConnection(output.Id);

            if (localProgram.ProgramStructure.ProgramStart.Contains(output))
            {
                localProgram.ProgramStructure.ProgramStart.Remove(output);
            }

            var blockContainingInput = localProgram.ProgramStructure.ProgramBlocks
                                       .FirstOrDefault(block => block.Block.Outputs.Contains(output));

            if (blockContainingInput != null)
            {
                blockContainingInput.Block.Outputs.Remove(output);
            }
        }
        await JSRuntime.InvokeVoidAsync("jsPlumbInterop.clearAllConnections");
        await DrawConnections(localProgram.ProgramStructure);
    }


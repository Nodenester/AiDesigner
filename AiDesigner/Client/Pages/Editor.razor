                                    // Check if programBlock.Inputs has a value at the same index
                                    if (programBlock.Inputs != null && index < programBlock.Inputs.Count && programBlock.Inputs[index] != Guid.Empty)
                                    {
                                        isInputConnectedToAnotherBlock = true;
                                    }

                                    // Show the input field if:

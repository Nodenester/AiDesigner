                        {
                            <div id="Input" class="node" style="left: @(customBlockProgram.ProgramStructure.ProgramStartLocation.Item1.ToString()+"px"); top: @(customBlockProgram.ProgramStructure.ProgramStartLocation.Item2.ToString()+"px");">

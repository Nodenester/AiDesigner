    private async Task UpdateDb(ProgramObject Program)
    {
        if (Program != null)
        {
            HttpResponseMessage response = null;
            try
            {
                var settings = new JsonSerializerSettings
                {
                        TypeNameHandling = TypeNameHandling.Auto,
                        Converters = new List<JsonConverter> { new TupleConverter(), new BlockJsonConverter() },
                        ContractResolver = new DefaultContractResolver
                        {
                            NamingStrategy = new CamelCaseNamingStrategy()
                        },
                        ReferenceLoopHandling = ReferenceLoopHandling.Serialize,
                        ObjectCreationHandling = ObjectCreationHandling.Replace
                };

                if (Program is CustomProgram customProgram)
                {
                    var json = JsonConvert.SerializeObject(customProgram, settings);
                    var content = new StringContent(json, Encoding.UTF8, "application/json");

                    response = await Http.PutAsync($"programs/{customProgram.Id}", content);
                }
                else if (Program is CustomBlockProgram customBlockProgram)
                {
                    var json = JsonConvert.SerializeObject(customBlockProgram, settings);
                    var content = new StringContent(json, Encoding.UTF8, "application/json");

                    response = await Http.PutAsync($"customblocks/{customBlockProgram.Id}", content);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("An error occurred while sending the request: " + ex.ToString());
            }

            if (response == null || !response.IsSuccessStatusCode)
            {
                string errorContent = await response.Content.ReadAsStringAsync();
                throw new Exception($"Failed to update program with ID {Program.Id}. Response: {errorContent}. Code {response.StatusCode}");
            }
        }
        else
        {
            throw new Exception($"No active program");
        }
    }

    private List<string> CheckErrors(ProgramObject Program)
    {
        if (Program == null)
        {
            throw new ArgumentNullException(nameof(Program), "No active program");
        }

        try
        {
            switch (Program)
            {
                case CustomProgram customProgram:
                    return customProgram.ProgramStructure.CheckErrors();
                case CustomBlockProgram customBlockProgram:
                    return customBlockProgram.ProgramStructure.CheckErrors();
                default:
                    return new List<string> { $"What type is program? This is impossible. Program type: {Program.GetType().Name}" };
            }
        }
        catch (Exception ex)
        {
            throw new Exception($"Error while checking errors in the program. Inner Exception: {ex.Message}", ex);
        }
    }

    private void AddToHistory(ProgramObject program)
    {
        // Clone the program before adding it to the history
        var clonedProgram = Clone(program);

        // If the current history index is not at the end, remove all entries after the current index
        if (_currentHistoryIndex < History.Count - 1)
        {
            History.RemoveRange(_currentHistoryIndex + 1, History.Count - _currentHistoryIndex - 1);
        }

        // Add the cloned program to the history
        History.Add(clonedProgram);
        _currentHistoryIndex = History.Count - 1; // update the current index to the end of the history

        if (clonedProgram is CustomProgram customBlock)
        {
            Console.WriteLine("Program start location in clone " + customBlock.ProgramStructure.ProgramStartLocation.Item1 + customBlock.ProgramStructure.ProgramStartLocation.Item2);
        }

        // If the history exceeds MaxHistoryLength, remove the oldest entry
        if (History.Count > MaxHistoryLength)
        {
            History.RemoveAt(0);
            _currentHistoryIndex--; // don't forget to adjust the current index accordingly
        }
    }


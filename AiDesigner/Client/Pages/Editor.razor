                                        <span style="margin-left: 10px;">@node.Block.Name</span>
                                    </div>
                                    <div class="main-part dark:bg-gray-700">
                                        <div class="left-part">
                                            <!-- Left part content goes here -->
                                            @foreach (var input in node.Block.Inputs)
                                            {
                                                <div class="node-input d-flex ">
                                                <div id="@input.Id" class="@GetShape(input.Type.ToString()) @GetColor(input.Type.ToString()) Connection" @onclick="() => TryConnect(input)"></div>
                                                    <span class="small-font">@input.Name</span>
                                                </div>

                                            }
                                        </div>
                                        <div class="right-part">
                                            <!-- Right part content goes here -->
                                            @foreach (var output in node.Block.Outputs)
                                            {
                                                <div class="node-output d-flex ">
                                                    <span class="small-font">@output.Name</span>
                                                    <div id="@output.Id" class="@GetShape(output.Type.ToString()) @GetColor(output.Type.ToString()) Connection" @onclick="() => SelectOutput(output)"></div>
                                                </div>

                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            <div id="error-shower" class="flex-auto bg-gray-800 dark:bg-gray-800 text-white py-3 mt-auto">
                <!-- Error Shower Content -->
                @foreach (var x in Errors)
                {
                    <p class="text-white px-4" >@x</p>
                }
            </div>
        </div>

        <div id="right-side" class="resizable-x right-side w-2/12 bg-gray-200 dark:bg-gray-700 overflow-auto" style="width: 16.666667%;">
            <div class="details-box p-0 border-b border-gray-300 dark:border-gray-600">
                <p class="dark:bg-gray-700 border-gray-700 w-full align-top px-1">Details</p>
                <!-- Block Settings Content -->
                @if (SelectedDetail is ProgramBlock programBlock)
                {
                    <div class="p-1">
                        <h4 class="mt-0">Inputs</h4>
                        @foreach (var (input, index) in programBlock.Block.Inputs.Select((value, idx) => (value, idx)))
                        {
                            <div class="align-top">
                                @if (localProgram is CustomProgram customProgram1)
                                {
                                    bool isInputInDirectInputs = customProgram1.ProgramStructure.DirectInputValues.ContainsKey(input.Id);

                                    bool isValueEmpty = true;
                                    // Safely get value from DirectInputValues
                                    if (customProgram1.ProgramStructure.DirectInputValues.TryGetValue(input.Id, out var directValue))
                                    {
                                        isValueEmpty = string.IsNullOrEmpty(directValue?.ToString());
                                    }

                                    bool isInputConnectedToProgramInput = customProgram1.ProgramStructure.InputValues.ContainsKey(input.Id);

                                    bool isInputConnectedToAnotherBlock = false;

                                    // Check if programBlock.Inputs has a value at the same index
                                    if (programBlock.Inputs != null && index < programBlock.Inputs.Count && programBlock.Inputs[index] != Guid.Empty)
                                    {
                                        isInputConnectedToAnotherBlock = true;
                                    }

                                    // Show the input field if:
                                    // 1. It's in DirectInputValues and its value is not empty
                                    // 2. It's not connected to another block
                                    // 3. It's not connected to a program input
                                    if ((isInputInDirectInputs && !isValueEmpty) || (!isInputConnectedToAnotherBlock && !isInputConnectedToProgramInput))
                                    {
                                        if(input.Name != "Trigger")
                                        {
                                            <label class="text-gray-200">@input.Name:</label>
                                        }

                                        // If the input doesn't exist in DirectInputValues, initialize it
                                        if (!isInputInDirectInputs)
                                        {
                                            customProgram1.ProgramStructure.DirectInputValues[input.Id] = "";
                                        }
                                        else
                                        {
                                            Console.WriteLine("Direct input value: " + customProgram1.ProgramStructure.DirectInputValues[input.Id]);
                                        }

                                        if (input.Name != "Trigger")
                                        {
                                            <!-- Styling the text input for dark mode using Tailwind -->
                                            <div class="bg-white dark:!bg-gray-800 p-4 rounded-lg mb-2 shadow hover:shadow-lg transition">
                                                @switch (input.Type)
                                                {
                                                    case NodeBaseApi.Version2.Type.Trigger:
                                                        @*                                                     <div class="mb-2">
                                                        <p class="font-semibold">Type: Trigger</p>

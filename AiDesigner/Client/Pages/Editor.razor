                                            Create input
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div id="Output" class="node" style="left: @(customBlockProgram.ProgramStructure.ProgramEndLocation.Item1.ToString()+"px"); top: @(customBlockProgram.ProgramStructure.ProgramEndLocation.Item2.ToString()+"px");">
                                <div class="top-part dark:bg-gray-800">
                                    <span style="margin-left: 10px;">Output</span>
                                </div>
                                <div class="main-part dark:bg-gray-700">
                                    <div class="left-part">
                                        @foreach (var input in customBlockProgram.ProgramStructure.ProgramEnd)

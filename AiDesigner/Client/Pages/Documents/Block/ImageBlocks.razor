@page "/documentation/block/imageprocessing"

<div class="container mx-auto p-6 font-mono">
    <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Image Processing Blocks</h2>

        <!-- Image Resize Block -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">ImageResize</h3>
            <p>Resizes an image to the specified dimensions.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Image: The input image. (Type: Picture) <span class="text-red-500">*</span></li>
                <li>Width: The new width. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Height: The new height. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Resized Image: The resized image. (Type: Picture)</li>
            </ul>
        </div>

        <!-- Image Rotate Block -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">ImageRotate</h3>
            <p>Rotates an image by the specified angle.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Image: The input image. (Type: Picture) <span class="text-red-500">*</span></li>
                <li>Angle: The angle to rotate the image. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Rotated Image: The rotated image. (Type: Picture)</li>
            </ul>
        </div>

        <!-- Image Grayscale Block -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">ImageGrayscale</h3>
            <p>Converts an image to grayscale.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Image: The input image. (Type: Picture) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Grayscale Image: The grayscale image. (Type: Picture)</li>
            </ul>
        </div>

        <!-- Depth Map Block -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">DepthMap</h3>
                <p>Generates a depth map from a stereo pair of images.</p>
                <h4 class="font-bold mt-2">Inputs:</h4>
                <ul class="list-disc pl-4 ml-6 mb-2">
                    <li>Left Image: The left image of the stereo pair. (Type: Picture) <span class="text-red-500">*</span></li>
                    <li>Right Image: The right image of the stereo pair. (Type: Picture) <span class="text-red-500">*</span></li>
                </ul>
                <h4 class="font-bold">Outputs:</h4>
                <ul class="list-disc pl-4 ml-6 mb-2">
                    <li>Depth Map: The generated depth map. (Type: Picture)</li>
                </ul>
        </div>

        <!-- Threshold Block -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Threshold</h3>
            <p>Applies a threshold to an image.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Image: The input image. (Type: Picture) <span class="text-red-500">*</span></li>
                <li>Threshold Value: The threshold value. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Thresholded Image: The thresholded image. (Type: Picture)</li>
            </ul>
        </div>

        <!-- Blur Block -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Blur</h3>
            <p>Applies blurring to an image.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Image: The input image. (Type: Picture) <span class="text-red-500">*</span></li>
                <li>Kernel Size: The size of the kernel used for blurring. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Blurred Image: The blurred image. (Type: Picture)</li>
            </ul>
        </div>

        <!-- Edge Detection Block -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">EdgeDetection</h3>
            <p>Detects edges in an image using the Canny edge detection algorithm.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Image: The input image. (Type: Picture) <span class="text-red-500">*</span></li>
                <li>Lower Threshold: The lower threshold for edge detection. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Upper Threshold: The upper threshold for edge detection. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Edges: The edges detected in the image. (Type: Picture)</li>
            </ul>
        </div>
    </section>
</div>


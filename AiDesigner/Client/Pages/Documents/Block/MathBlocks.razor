@page "/documentation/block/mathblocks"

<div class="container mx-auto p-6 font-mono">
    <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Mathematical Operation Blocks</h2>

        <!-- Add Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">AddBlock</h3>
            <p>Adds two numbers together.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The first number to add. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The second number to add. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Sum: The sum of the two numbers. (Type: Number)</li>
            </ul>
        </div>

        <!-- Subtract Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">SubtractBlock</h3>
            <p>Subtracts the second number from the first number.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The number to subtract from. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The number to subtract. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Difference: The difference of the two numbers. (Type: Number)</li>
            </ul>
        </div>

        <!-- Multiply Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
                        <h3 class="text-xl font-bold mb-2">MultiplyBlock</h3>
            <p>Multiplies two numbers together.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The first number to multiply. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The second number to multiply. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Product: The product of the two numbers. (Type: Number)</li>
            </ul>
        </div>

        <!-- Divide Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">DivideBlock</h3>
            <p>Divides the first number by the second number.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The number to divide. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The number to divide by. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Quotient: The quotient of the two numbers. (Type: Number)</li>
            </ul>
        </div>

        <!-- Modulus Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">ModulusBlock</h3>
            <p>Calculates the remainder of the division of the first number by the second number.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The dividend. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The divisor. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Remainder: The remainder of the division. (Type: Number)</li>
            </ul>
        </div>

        <!-- Power Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">PowerBlock</h3>
            <p>Raises the first number to the power of the second number.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Base: The base number. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Exponent: The exponent. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: The result of the operation. (Type: Number)</li>
            </ul>
        </div>

        <!-- Square Root Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">SquareRootBlock</h3>
            <p>Calculates the square root of a number.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Number: The number. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: The square root of the number. (Type: Number)</li>
            </ul>
        </div>

        <!-- Absolute Value Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">AbsoluteValueBlock</h3>
            <p>Calculates the absolute value of a number.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Number: The number. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: The absolute value of the number. (Type: Number)</li>
            </ul>
        </div>

        <!-- Random Number Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">RandomNumberBlock</h3>
            <p>Generates a random number between the specified minimum and maximum values.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Min: Minimum value (inclusive). (Type: Number) <span class="text-red-500">*</span></li>
                <li>Max: Maximum value (exclusive). (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: The generated random number. (Type: Number)</li>
            </ul>
        </div>
    </section>
</div>


@page "/documentation/block/booleanblocks"

<div class="container mx-auto p-6 font-mono">
    <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Logical Blocks</h2>

        <!-- AndBlock -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">And Block</h3>
            <p>A block that performs a logical AND operation.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Input 1: First input (Type: Boolean) <span class="text-red-500">*</span></li>
                <li>Input 2: Second input (Type: Boolean) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Output: Output of the AND operation (Type: Boolean)</li>
            </ul>
        </div>

        <!-- OrBlock -->
        <div class="mb-4 dark:!bg-gray-700 bg-gray-100 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Or Block</h3>
            <p>A block that performs a logical OR operation.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Input 1: First input (Type: Boolean) <span class="text-red-500">*</span></li>
                <li>Input 2: Second input (Type: Boolean) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Output: Output of the OR operation (Type: Boolean)</li>
            </ul>
        </div>


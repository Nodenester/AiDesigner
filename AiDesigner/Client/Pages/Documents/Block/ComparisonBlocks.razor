@page "/documentation/block/comparisonblocks"

<div class="container mx-auto p-6 font-mono">
    <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Mathematical Operation Blocks</h2>
        <!-- Greater Than Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Greater Than Block</h3>
            <p>Compares two numbers to see if the first is greater than the second.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The first number. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The second number. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: True if First Number > Second Number, false otherwise. (Type: Boolean)</li>
            </ul>
        </div>

        <!-- Less Than Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Less Than Block</h3>
            <p>Compares two numbers to see if the first is less than the second.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The first number. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The second number. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: True if First Number &lt; Second Number, false otherwise. (Type: Boolean)</li>
            </ul>
        </div>

        <!-- Equal To Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Equal To Block</h3>
            <p>Compares two numbers for equality.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The first number. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The second number. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: True if First Number == Second Number, false otherwise. (Type: Boolean)</li>
            </ul>
        </div>

        <!-- Not Equal To Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Not Equal To Block</h3>
            <p>Compares two numbers for inequality.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The first number. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The second number. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: True if First Number != Second Number, false otherwise. (Type: Boolean)</li>
            </ul>
        </div>

        <!-- Greater Than Or Equal To Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Greater Than Or Equal To Block</h3>
            <p>Compares two numbers to see if the first is greater than or equal to the second.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The first number. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The second number. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: True if First Number >= Second Number, false otherwise. (Type: Boolean)</li>
            </ul>
        </div>

        <!-- Less Than Or Equal To Block -->
        <div class="mb-4 bg-gray-700 p-4 rounded">
            <h3 class="text-xl font-bold mb-2">Less Than Or Equal To Block</h3>
            <p>Compares two numbers to see if the first is less than or equal to the second.</p>
            <h4 class="font-bold mt-2">Inputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>First Number: The first number. (Type: Number) <span class="text-red-500">*</span></li>
                <li>Second Number: The second number. (Type: Number) <span class="text-red-500">*</span></li>
            </ul>
            <h4 class="font-bold">Outputs:</h4>
            <ul class="list-disc pl-4 ml-6 mb-2">
                <li>Result: True if First Number &lt;= Second Number, false otherwise. (Type: Boolean)</li>
            </ul>
        </div>
    </section>
</div>


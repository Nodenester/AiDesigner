@page "/documentation/introduction/overview"

<div class="container mx-auto p-6 font-mono">
    <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Welcome to AiDesigner</h2>

        <!-- Key Features Snapshot -->
        <div class="mb-2 grid grid-cols-3 gap-4">
            <div class="flex flex-col bg-gray-700 p-4 rounded">
                <h3 class="text-xl font-bold mb-2">Visual Programming</h3>
                <p class="flex-grow">Design and create AI projects using an intuitive block-based interface.</p>

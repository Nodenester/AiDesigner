@page "/chat"
@using AiDesigner.Client.Pages.Marketplace;
@using AiDesigner.Client.Components;
@using AiDesigner.Shared.Data;
@using Microsoft.AspNetCore.Authorization;
@using Newtonsoft.Json;
@using Newtonsoft.Json.Serialization;
@using NodeBaseApi.Version2;
@inject HttpClient Http
@attribute [Authorize]

<div class="flex bo" style="height: 81%;">
    <!-- Select Program box -->
    <div class="flex-shrink-0 flex flex-col dark:bg-gray-700 w-72 rounded-lg">
        @if (customPrograms != null && workshopPrograms != null)
        {
            <div class="text-center p-4 overflow-y-auto" style="height: 50%;">
                <p class="text-lg font-semibold mb-4">Your Programs</p>
                @foreach (var program in customPrograms)
                {
                    <div class="mb-2 h-12">
                        <button class="@(selectedProgram == program ? "dark:!bg-gray-600" : "dark:!g-gray-800") hover:dark:!bg-gray-600 text-white w-full h-full p-2 rounded-lg shadow hover:shadow-lg transition"
                        @onclick="() => SetSelectedProgram(program)">
                            @program.Name
                        </button>
                    </div>
                }
            </div>
            <div class="text-center p-4 overflow-y-auto" style="height: 40%;">
                <p class="text-lg font-semibold mb-4">Vaulted Programs</p>
                @foreach (var program in workshopPrograms)
                {
                    <div class="mb-2 h-12">
                        <button class="@(selectedProgram == program ? "dark:!bg-gray-600" : "dark:!g-gray-800") hover:dark:!bg-gray-600 text-white w-full h-full p-2 rounded-lg shadow hover:shadow-lg transition"
                        @onclick="() => SetSelectedProgram(program)">
                            @program.Name
                        </button>
                    </div>
                }
            </div>
        }
    </div>
    <!-- Input box -->
    <div class="flex-grow text-center p-4 overflow-y-auto" style="max-height: 100%; max-width: 45%;">
        <p class="text-lg font-semibold mb-4">Program Inputs</p>
        @if (selectedProgram != null)
        {
            <div style="margin-top: 0rem;">
                @foreach (var input in selectedProgram.ProgramStructure.ProgramStart)
                {
                    if (input.Name == "Start")
                    {
                        continue;
                    }
                    <div class="bg-white dark:!bg-gray-800 p-4 rounded-lg mb-2 shadow hover:shadow-lg transition">
                        @switch (input.Type)
                        {
@*                             case NodeBaseApi.Version2.Type.Trigger:
                                <div class="mb-2">
                                    <p class="font-semibold">Type: Trigger</p>
                                    <button class="bg-blue-500 dark:!bg-gray-800 hover:dark:!bg-gray-600 text-white w-full mt-2 p-2 rounded hover:bg-blue-600">
                                        Trigger @input.Name
                                    </button>
                                </div>
                                break; *@
                            case NodeBaseApi.Version2.Type.String:
                                <div class="mb-2">
                                    <p class="font-semibold">Type: Text</p>
                                    <textarea @onchange="@(e => UpdateValue(e, input.Id))"
                                              class="w-full p-2 border rounded dark:bg-gray-600 dark:text-white outline-none border-0"
                                              placeholder="@input.Name"></textarea>
                                </div>
                                break;
                            case NodeBaseApi.Version2.Type.Picture:
                                <div class="mb-2">
                                    <p class="font-semibold">Type: Picture</p>
                                    <div>
                                        <div class="flex items-center justify-center w-full">
                                            <label for="dropzone-file" class="flex flex-col items-center justify-center w-full h-48 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 dark:hover:bg-bray-800 dark:bg-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:hover:border-gray-500 dark:hover:bg-gray-600">
                                                <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                                    <svg class="w-8 h-8 mb-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
                                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 13h3a3 3 0 0 0 0-6h-.025A5.56 5.56 0 0 0 16 6.5 5.5 5.5 0 0 0 5.207 5.021C5.137 5.017 5.071 5 5 5a4 4 0 0 0 0 8h2.167M10 15V6m0 0L8 8m2-2 2 2" />
                                                    </svg>
                                                    <p class="mb-2 text-sm text-gray-500 dark:text-gray-400"><span class="font-semibold">Click to upload</span> or drag and drop</p>
                                                    <p class="text-xs text-gray-500 dark:text-gray-400">PNG or JPG (MAX. 260x260px)</p>
                                                </div>
                                                <InputFile id="dropzone-file" class="hidden" accept=".png" OnChange="@(async (e) => await OnSingleFileChanged(e, input.Id))" />
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                break;
                            case NodeBaseApi.Version2.Type.Number:
                                <div class="mb-2">
                                    <p class="font-semibold">Type: Number</p>
                                    <input type="number" @onchange="@(e => UpdateValue(e, input.Id))"
                                           class="w-full p-2 border rounded dark:bg-gray-600 dark:text-white outline-none border-0" placeholder="@input.Name" />
                                </div>
                                break;
                            case NodeBaseApi.Version2.Type.Boolean:
                                <div class="mb-2">
                                    <p class="font-semibold w-full">Type: Boolean</p>
                                    <div class="mt-2 w-full flex justify-center">
                                        <div class="w-72 cursor-pointer flex items-center justify-center">
                                            <label for="@input.Id" class="flex items-center justify-center h-12 w-full">
                                                <input type="checkbox" id="@input.Id" @onchange="@(e => UpdateValue(e, input.Id))"
                                                       class="w-6 h-6 accent-green-600 text-gray-600 bg-gray-100 border-gray-300 rounded focus:ring-gray-500 dark:focus:ring-gray-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600" />
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                break;
                            case NodeBaseApi.Version2.Type.Audio:
                                <div class="mb-2">
                                    <p class="font-semibold">Type: Audio</p>
                                    <div>
                                        <div class="flex items-center justify-center w-full">
                                            <label for="audio-dropzone-file" class="flex flex-col items-center justify-center w-full h-48 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 dark:hover:bg-gray-800 dark:bg-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:hover:border-gray-500 dark:hover:!bg-gray-600">
                                                <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                                    <svg class="w-8 h-8 mb-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
                                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 13h3a3 3 0 0 0 0-6h-.025A5.56 5.56 0 0 0 16 6.5 5.5 5.5 0 0 0 5.207 5.021C5.137 5.017 5.071 5 5 5a4 4 0 0 0 0 8h2.167M10 15V6m0 0L8 8m2-2 2 2" />
                                                    </svg>
                                                    <p class="mb-2 text-sm text-gray-500 dark:text-gray-400"><span class="font-semibold">Click to upload</span> or drag and drop</p>
                                                    <p class="text-xs text-gray-500 dark:text-gray-400">MP3, WAV or other audio formats</p>
                                                </div>
                                                <InputFile id="audio-dropzone-file" class="hidden" accept=".mp3,.wav" OnChange="@(async (e) => await OnSingleAudioFileChanged(e, input.Id))" />
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                break;
                            default:
                                <p>Unknown input type</p>
                                break;
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- Center line -->
    <div class="flex flex-col items-center h-full">
        <!-- Vertical Line -->
        <div class="bg-gray-500 w-[2px] flex-grow"></div>

        <!-- Button -->
        <div class="align-center mb-0 mt-auto">
            <button class="py-1 bg-green-600 text-white rounded mt-4 px-6 h-12" @onclick="ExecuteProgram">
                Execute Program
            </button>
        </div>
    </div>

    <!-- Output box -->
    <div class="flex-grow text-center p-4">
        <p class="text-lg font-semibold mb-4">Program Outputs</p>
        @if (selectedProgram != null)
        {
            <div style="margin-top: 0rem;">
                @foreach (var output in selectedProgram.ProgramStructure.ProgramEnd)
                {
                    if (output.Name == "End")
                    {
                        continue;
                    }
                    var index = selectedProgram.ProgramStructure.ProgramEnd.IndexOf(output) - 1;
                    <div class="bg-white dark:!bg-gray-800 p-4 rounded-lg mb-2 shadow hover:shadow-lg transition">
                        @switch (output.Type)
                        {
                            case NodeBaseApi.Version2.Type.Picture:
                                <p class="font-semibold">Type: Picture</p>
                                if (ProgramOutput.Count() > 0 && ProgramOutput.ToArray()[index] != null)
                                {
                                    <img src="@($"data:image/png;base64,{Convert.ToBase64String((byte[])ProgramOutput.ToArray()[index])}")" alt="@output.Name" />
                                }
                                break;
                            case NodeBaseApi.Version2.Type.String:
                                <p class="font-semibold">Type: Text</p>
                                if (ProgramOutput.Count() > 0 && ProgramOutput.ToArray()[index] != null)
                                {
                                    <p>@ProgramOutput.ToArray()[index]</p>
                                }
                                break;
                            case NodeBaseApi.Version2.Type.Number:
                                <p class="font-semibold">Type: Number</p>
                                if (ProgramOutput.Count() > 0 && ProgramOutput.ToArray()[index] != null)
                                {
                                    <p>@ProgramOutput.ToArray()[index]</p>
                                }
                                break;
                            case NodeBaseApi.Version2.Type.Boolean:
                                <p class="font-semibold">Type: Boolean</p>
                                if (ProgramOutput.Count() > 0 && ProgramOutput.ToArray()[index] != null)
                                {
                                    if (ProgramOutput.ToArray()[index].ToString() == "True")
                                    {
                                        <p>True</p>
                                    }
                                    else
                                    {
                                        <p>False</p>
                                    }
                                }
                                break;
                            case NodeBaseApi.Version2.Type.Audio:
                                <p class="font-semibold">Type: Audio</p>
                                if (ProgramOutput.Count() > 0 && ProgramOutput.ToArray()[index] != null)
                                {
                                    <audio controls>
                                        <source src="@($"data:audio/wav;base64,{Convert.ToBase64String((byte[])ProgramOutput.ToArray()[index])}")" type="audio/wav">
                                        Your browser does not support the audio element.
                                    </audio>
                                }
                                break;
                            default:
                                <p>Unknown output type</p>
                                break;
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>


@code {
    [CascadingParameter(Name = "CascAuth")]
    public AuthenticationState CascAuth { get; set; }

    public CustomProgram selectedProgram { get; set; }

    public List<CustomProgram> customPrograms { get; set; }
    public List<CustomProgram> workshopPrograms { get; set; }

    JsonSerializerSettings settings = new JsonSerializerSettings
        {
            TypeNameHandling = TypeNameHandling.Auto,
            Converters = new List<JsonConverter> { new TupleConverter(), new BlockJsonConverter() },
            ContractResolver = new DefaultContractResolver
            {
                NamingStrategy = new CamelCaseNamingStrategy()
            },
            ReferenceLoopHandling = ReferenceLoopHandling.Serialize,
            ObjectCreationHandling = ObjectCreationHandling.Replace
        };

    ApiService apiService = new ApiService("https://localhost:44313/");

    List<object> ProgramOutput { get; set; } = new List<object>();

    protected override async Task OnInitializedAsync()
    {

    }

    private async Task ExecuteProgram()
    {
        var nonNullInputValues = selectedProgram.ProgramStructure.InputValues
            .Where(kvp => kvp.Value != null)
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);

        ProgramOutput = await apiService.ExecuteProgramAsync(selectedProgram.ApiKey, nonNullInputValues, "56a2d82a-5595-4a8f-b1fd-9a1482e02d20", null, true);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (CascAuth != null)
        {
            var user = CascAuth.User;
            var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
            if (Guid.TryParse(userIdClaim, out Guid userId))
            {
                await GetCustomPrograms(userId.ToString());
                await GetWorkshopPrograms(userId.ToString());
            }
        }
    }

    private void UpdateValue(ChangeEventArgs e, Guid id)
    {
        selectedProgram.ProgramStructure.InputValues[id] = e.Value?.ToString();
    }

    private void SetSelectedProgram(CustomProgram customProgram)
    {
        selectedProgram = customProgram;

        foreach (var input in selectedProgram.ProgramStructure.ProgramStart)
        {
            if (!selectedProgram.ProgramStructure.InputValues.ContainsKey(input.Id))
            {
                selectedProgram.ProgramStructure.InputValues[input.Id] = selectedProgram.ProgramStructure.InputValues.ContainsKey(input.Id)
                    ? selectedProgram.ProgramStructure.InputValues[input.Id]
                    : null;
            }
        }
        foreach (var input in selectedProgram.ProgramStructure.ProgramEnd)
        {
            if (!selectedProgram.ProgramStructure.OutputValues.ContainsKey(input.Id))
            {
                selectedProgram.ProgramStructure.OutputValues[input.Id] = selectedProgram.ProgramStructure.OutputValues.ContainsKey(input.Id)
                    ? selectedProgram.ProgramStructure.OutputValues[input.Id]
                    : null;
            }
        }
    }

    private async Task GetCustomPrograms(string userId)
    {
        string requestUri = $"Chat/Programs/{userId}";
        HttpResponseMessage httpResponse = await Http.GetAsync(requestUri);
        if (httpResponse.IsSuccessStatusCode && customPrograms == null)
        {
            string content = await httpResponse.Content.ReadAsStringAsync();
            customPrograms = JsonConvert.DeserializeObject<List<CustomProgram>>(content, settings);
            //Console.WriteLine("Programs: " + content);
        }
        else
        {
            Console.WriteLine($"Failed to fetch custom programs. Status code: {httpResponse.StatusCode}");
        }
    }

    private async Task GetWorkshopPrograms(string userId)
    {
        string requestUri = $"Chat/Workshop/{userId}";
        HttpResponseMessage httpResponse = await Http.GetAsync(requestUri);
        if (httpResponse.IsSuccessStatusCode && workshopPrograms == null)
        {
            string content = await httpResponse.Content.ReadAsStringAsync();
            workshopPrograms = JsonConvert.DeserializeObject<List<CustomProgram>>(content, settings);
            //Console.WriteLine("WPrograms: " + content);
        }
        else
        {
            Console.WriteLine($"Failed to fetch workshop programs. Status code: {httpResponse.StatusCode}");
        }
    }

    private async Task OnSingleFileChanged(InputFileChangeEventArgs e, Guid id)
    {
        var file = e.File;
        string[] imageTypes = new[] { "image/jpeg", "image/png" };

        if (file != null && imageTypes.Contains(file.ContentType))
        {
            // Resizing the image
            var resized = await file.RequestImageFileAsync(file.ContentType, 260, 260);

            var buffer = new byte[resized.Size];
            await using var stream = resized.OpenReadStream((int)resized.Size);
            await stream.ReadAsync(buffer, 0, (int)resized.Size);

            selectedProgram.ProgramStructure.InputValues[id] = buffer;
        }
    }

    private async Task OnSingleAudioFileChanged(InputFileChangeEventArgs e, Guid inputId)
    {
        var file = e.File;
        if (file != null)
        {
            using (var ms = new MemoryStream())
            {
                await file.OpenReadStream().CopyToAsync(ms);
                var bytes = ms.ToArray();
                // Now 'bytes' is a byte array you can use.
                selectedProgram.ProgramStructure.InputValues[inputId] = bytes;
            }
        }
    }
}

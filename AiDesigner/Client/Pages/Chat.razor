@page "/chat"
@using AiDesigner.Client.Pages.Marketplace;
@using AiDesigner.Client.Components;
@using AiDesigner.Shared.Data;
@using Microsoft.AspNetCore.Authorization;
@using Newtonsoft.Json;
@using Newtonsoft.Json.Serialization;
@using NodeBaseApi.Version2;
@using System.Text
@using static AiDesigner.Client.Components.InputList;
@inject AuthenticationStateProvider AuthenticationStateProvider;
@inject HttpClient Http
@attribute [Authorize]
@inject TooltipService tooltipService


<div class="flex bo" style="height: 81%;">
    <!-- Select Program box -->
    <div class="flex-shrink-0 flex flex-col dark:bg-gray-700 w-72 rounded-lg">
        @if (customPrograms != null && workshopPrograms != null)
        {
            <div class="text-center p-4 overflow-y-auto" style="height: 50%;">
                <p class="text-lg font-semibold mb-4">Your Programs</p>
                @foreach (var program in customPrograms)
                {
                    <div class="mb-2 h-12">
                        <button @ref='programButtonReferences[(program.Id, "custom")]'
                                @onmouseenter='() => ShowTooltip(program.Id, "custom")'
                                @onmouseleave="HideTooltip"
                                class="@(selectedProgram == program ? "dark:!bg-gray-600" : "dark:!g-gray-800") hover:dark:!bg-gray-600 text-white w-full h-full p-2 rounded-lg shadow hover:shadow-lg transition"
                                @onclick="() => SetSelectedProgram(program)">
                            @program.Name
                        </button>
                    </div>
                }
            </div>
            <div class="text-center p-4 overflow-y-auto" style="height: 40%;">
                <p class="text-lg font-semibold mb-4">Vaulted Programs</p>
                @foreach (var program in workshopPrograms)
                {
                    <div class="mb-2 h-12">
                        <button @ref='programButtonReferences[(program.Id, "")]'
                                @onmouseenter='() => ShowTooltip(program.Id, "")'
                                @onmouseleave="HideTooltip"
                                class="@(selectedProgram == program ? "dark:!bg-gray-600" : "dark:!g-gray-800") hover:dark:!bg-gray-600 text-white w-full h-full p-2 rounded-lg shadow hover:shadow-lg transition"
                                @onclick="() => SetSelectedProgram(program)">
                            @program.Name
                        </button>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Input box -->
    <div class="box-style text-center p-4 pt-2 overflow-y-auto">
        <p class="text-lg font-semibold mb-2">Program Inputs</p>
        @if (selectedProgram != null)
        {
            <div>
                @foreach (var input in selectedProgram.ProgramStructure.ProgramStart)
                {
                    if (input.Name == "Start")
                    {
                        continue;
                    }
                    <div class="item-style bg-white dark:!bg-gray-800 p-4 rounded-lg mb-2 shadow hover:shadow-lg transition">
                        <InputList Id="input.Id" Type="input.Type" Value="selectedProgram.ProgramStructure.InputValues[input.Id]" IsList="input.IsList" Placeholdervalue="input.Name" SendbackValue="SetValue"></InputList>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Center line -->
    <div class="flex flex-col items-center h-full">
        <!-- Vertical Line -->
        <div class="bg-gray-500 w-[2px] flex-grow"></div>

        <!-- Session dropdown -->
        @if (selectedProgram != null && selectedProgram.SupportsSessions)
        {
            <div class="mt-2">
                <SelectSession IsDark="true" SelectSessions="setCurrentSession" ProgramId="@selectedProgram.Id.ToString()"></SelectSession>
            </div>
        }

        <!-- Button -->
        <div class="align-center mb-0 mt-2">
            <button class="py-1 rounded px-6 h-12 w-48 @(isLoading ? "bg-gray-500 cursor-not-allowed" : isExecutionFailed ? "bg-red-600" : "bg-green-600 hover:bg-green-700") text-white"
                    @onclick="ExecuteProgram"
                    disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Loading...</span>
                }
                else if (isExecutionFailed)
                {
                    <span>Failed</span>
                }
                else
                {
                    <span>Execute Program</span>
                }
            </button>
        </div>
    </div>

    <!-- Output box -->
    <div class="box-style flex flex-col items-center text-center p-4 pt-2 overflow-y-auto">
        <p class="text-lg font-semibold mb-2">Program Outputs</p>
        @if (selectedProgram != null)
        {
            <div class="flex flex-col justify-end items-end w-full">
                @foreach (var output in ProgramOutput)
                {
                    <div class="bg-white dark:!bg-gray-800 p-4 rounded-lg mb-2 shadow hover:shadow-lg transition" style="min-width: 100%;">
                        <OutputDisplay OutputItem="@output" />
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .box-style {
        width: 40%; /* or use w-1/3 from Tailwind directly in the HTML class attribute */
    }

    .item-style {
        margin-top: 0rem;
    }
</style>

@code {
    [CascadingParameter(Name = "CascAuth")]
    public AuthenticationState CascAuth { get; set; }

    [CascadingParameter(Name = "Settokens")]
    protected EventCallback<int> SetTokens { get; set; }

    public CustomProgram selectedProgram { get; set; }

    public List<CustomProgram> customPrograms { get; set; }
    public List<CustomProgram> workshopPrograms { get; set; }

    JsonSerializerSettings settings = new JsonSerializerSettings
        {
            TypeNameHandling = TypeNameHandling.Auto,
            Converters = new List<JsonConverter> { new TupleConverter(), new BlockJsonConverter() },
            ContractResolver = new DefaultContractResolver
            {
                NamingStrategy = new CamelCaseNamingStrategy()
            },
            ReferenceLoopHandling = ReferenceLoopHandling.Serialize,
            ObjectCreationHandling = ObjectCreationHandling.Replace
        };

    List<object> ProgramOutput { get; set; } = new List<object>();

    Session currentSession = new Session();


    private bool isLoading = false;
    private bool isExecutionFailed = false;

    private Dictionary<(Guid, string), ElementReference> programButtonReferences = new Dictionary<(Guid, string), ElementReference>();

    void ShowTooltip(Guid programId, string source)
    {
        var key = (programId, source);
        if (programButtonReferences.TryGetValue(key, out var elementReference))
        {
            var programsList = source == "custom" ? customPrograms : workshopPrograms;
            var content = programsList.FirstOrDefault(p => p.Id == programId)?.Description;

            if (content != null)
            {
                tooltipService.Open(elementReference, content, new TooltipOptions
                    {
                        Position = TooltipPosition.Top,
                        Style = "max-width: 240px; white-space: normal; word-wrap: break-word;",          
                        Duration = 5000,
                        Delay = 500
                    });
            }
        }
    }

    void HideTooltip()
    {
        tooltipService.Close();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user != null)
        {
            var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
            if (Guid.TryParse(userIdClaim, out Guid userId))
            {
                await GetCustomPrograms(userId.ToString());
                await GetWorkshopPrograms(userId.ToString());
            }
        }
    }

    ApiService apiService = new ApiService("https://localhost:44313/");

    private async Task ExecuteProgram()
    {
        if (selectedProgram != null)
        {
            var nonNullInputValues = selectedProgram.ProgramStructure.InputValues
     .Where(kvp => kvp.Value != null)
     .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);

            if (CascAuth != null)
            {
                var user = CascAuth.User;
                var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
                if (Guid.TryParse(userIdClaim, out Guid userId))
                {
                    //ProgramOutput = await apiService.ExecuteProgramAsync(selectedProgram.ApiKey, nonNullInputValues, userId.ToString(), null, true);
                    var url = $"Execute?programKey={selectedProgram.ApiKey}&apiKey={userId}";

                    if (true)
                    {
                        url += $"&isTest=true";
                    }

                    if (selectedProgram.SupportsSessions)
                    {
                        url += $"&sessionId={currentSession?.SessionId}";
                    }

                    isLoading = true;
                    isExecutionFailed = false;
                    try
                    {

                        var requestContent = new StringContent(System.Text.Json.JsonSerializer.Serialize(nonNullInputValues), Encoding.UTF8, "application/json");
                        var response = await Http.PostAsync(url, requestContent);
                        var content = await response.Content.ReadAsStringAsync();

                        var responseContent = await response.Content.ReadAsStringAsync();
                        var outputValues = JsonConvert.DeserializeObject<List<object>>(responseContent);

                        if (response.IsSuccessStatusCode)
                        {
                            ProgramOutput = JsonConvert.DeserializeObject<List<object>>(responseContent);
                        }
                        else
                        {
                            isExecutionFailed = true;
                        }
                    }
                    catch (Exception ex)
                    {
                        isExecutionFailed = true;
                        Console.WriteLine($"Error executing program: {ex.Message}");
                    }
                    finally
                    {
                        isLoading = false;
                        if (isExecutionFailed)
                        {
                            StateHasChanged();
                            await Task.Delay(2000);
                            isExecutionFailed = false;
                        }
                    }
                    await GetTokens();
                }
            }
            StateHasChanged();
        }
    }

    private async Task GetTokens()
    {
        var user = CascAuth.User;
        if (user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
            if (!string.IsNullOrEmpty(userIdClaim) && Guid.TryParse(userIdClaim, out Guid userId))
            {
                try
                {
                    var response = await Http.PostAsJsonAsync<Guid>("Chat/Wallet/GetCreateWallet", userId);

                    if (response.IsSuccessStatusCode)
                    {
                        await SetTokens.InvokeAsync(await response.Content.ReadFromJsonAsync<int>());
                    }
                }
                catch (HttpRequestException ex)
                {
                    // Handle or log the HTTP request exception here...
                    Console.WriteLine($"HTTP request exception: {ex.Message}");
                }
                catch (JsonException ex)
                {
                    // Handle or log the deserialization exception here...
                    Console.WriteLine($"Failed to deserialize response: {ex.Message}");
                }
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {

    }

    private void SetValue(InputItem inputItem)
    {
        selectedProgram.ProgramStructure.InputValues[inputItem.Id] = inputItem.Data;
    }

    private void SetSelectedProgram(CustomProgram customProgram)
    {
        selectedProgram = customProgram;

        foreach (var input in selectedProgram.ProgramStructure.ProgramStart)
        {
            if (!selectedProgram.ProgramStructure.InputValues.ContainsKey(input.Id))
            {
                selectedProgram.ProgramStructure.InputValues[input.Id] = selectedProgram.ProgramStructure.InputValues.ContainsKey(input.Id)
                    ? selectedProgram.ProgramStructure.InputValues[input.Id]
                    : null;
            }
        }
        foreach (var input in selectedProgram.ProgramStructure.ProgramEnd)
        {
            if (!selectedProgram.ProgramStructure.OutputValues.ContainsKey(input.Id))
            {
                selectedProgram.ProgramStructure.OutputValues[input.Id] = selectedProgram.ProgramStructure.OutputValues.ContainsKey(input.Id)
                    ? selectedProgram.ProgramStructure.OutputValues[input.Id]
                    : null;
            }
        }
        currentSession = null;
    }

    private async Task GetCustomPrograms(string userId)
    {
        string requestUri = $"Chat/Programs/{userId}";
        HttpResponseMessage httpResponse = await Http.GetAsync(requestUri);
        if (httpResponse.IsSuccessStatusCode && customPrograms == null)
        {
            string content = await httpResponse.Content.ReadAsStringAsync();
            customPrograms = JsonConvert.DeserializeObject<List<CustomProgram>>(content, settings);
            //Console.WriteLine("Programs: " + content);
        }
        else
        {
            Console.WriteLine($"Failed to fetch custom programs. Status code: {httpResponse.StatusCode}");
        }
    }

    private async Task GetWorkshopPrograms(string userId)
    {
        string requestUri = $"Chat/Workshop/{userId}";
        HttpResponseMessage httpResponse = await Http.GetAsync(requestUri);
        if (httpResponse.IsSuccessStatusCode && workshopPrograms == null)
        {
            string content = await httpResponse.Content.ReadAsStringAsync();
            workshopPrograms = JsonConvert.DeserializeObject<List<CustomProgram>>(content, settings);
            //Console.WriteLine("WPrograms: " + content);
        }
        else
        {
            Console.WriteLine($"Failed to fetch workshop programs. Status code: {httpResponse.StatusCode}");
        }
    }

    private async Task OnSingleFileChanged(InputFileChangeEventArgs e, Guid id)
    {
        var file = e.File;
        string[] imageTypes = new[] { "image/jpeg", "image/png" };

        if (file != null && imageTypes.Contains(file.ContentType))
        {
            // Resizing the image
            var resized = await file.RequestImageFileAsync(file.ContentType, 260, 260);

            var buffer = new byte[resized.Size];
            await using var stream = resized.OpenReadStream((int)resized.Size);
            await stream.ReadAsync(buffer, 0, (int)resized.Size);

            selectedProgram.ProgramStructure.InputValues[id] = buffer;
        }
    }

    private async Task OnSingleAudioFileChanged(InputFileChangeEventArgs e, Guid inputId)
    {
        var file = e.File;
        if (file != null)
        {
            using (var ms = new MemoryStream())
            {
                await file.OpenReadStream().CopyToAsync(ms);
                var bytes = ms.ToArray();
                // Now 'bytes' is a byte array you can use.
                selectedProgram.ProgramStructure.InputValues[inputId] = bytes;
            }
        }
    }

    private void setCurrentSession(Session session)
    {
        currentSession = session;
    }
}

@page "/chat"
@using AiDesigner.Client.Pages.Marketplace;
@using AiDesigner.Client.Components;
@using AiDesigner.Shared.Data;
@using Microsoft.AspNetCore.Authorization;
@using Newtonsoft.Json;
@using Newtonsoft.Json.Linq
@using Newtonsoft.Json.Serialization;
@using NodeBaseApi.Version2;
@using System.Text
@using AiDesigner.Client.Components.Chat;
@inject AuthenticationStateProvider AuthenticationStateProvider;
@inject HttpClient Http
@attribute [Authorize]
@using Radzen
@using static AiDesigner.Client.Components.Chat.InputList
@inject TooltipService tooltipService
@inject NotificationService notificationService

<div class="flex bo" style="height: 100%;">
    <!-- Select Program box -->
    <div class="@($"flex-shrink-0 {(isSidebarActive ? "active" : "")}") flex flex-col bg-gray-100 dark:bg-gray-700 w-72">
        @if (customPrograms != null && workshopPrograms != null)
        {
            <div class="p-2 overflow-y-auto" style="height: 50%;">
                <p class="text-lg font-semibold mb-4 ml-4 dark:!text-white text-black">Your Programs</p>
                @foreach (var program in customPrograms)
                {
                    <div class="p-2 rounded-lg mb-2 h-12 flex hover:dark:!bg-gray-600 hover:!bg-white @(selectedProgram == program ? "dark:!bg-gray-600 bg-white" : "dark:!g-gray-800")">
                        <button @ref='programButtonReferences[(program.Id, "custom")]'
                                @onmouseenter='() => ShowTooltip(program.Id, "custom")'
                                @onmouseleave="HideTooltip"
                                class="flex items-center text-white w-full h-full"
                                @onclick="() => SetSelectedProgram(program)">
                            @if (program.Image != null)
                            {
                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(program.Image)" class="program-image mr-2">
                            }
                            <span class="ml-2 dark:!text-white text-black">
                                @program.Name
                            </span>
                        </button>
                    </div>
                }
            </div>
            <div class="p-2 overflow-y-auto" style="height: 40%;">
                <p class="text-lg font-semibold mb-4 ml-4 dark:!text-white text-black">Vaulted Programs</p>
                @if (workshopArticles != null)
                {
                    @foreach (var program in workshopArticles.Where(article => article.Type == "Program"))
                    {
                        var isSelected = selectedProgram?.Id.ToString() == program.ProgramId;
                        <div class="p-2 rounded-lg mb-2 h-12 flex hover:dark:!bg-gray-600 @(isSelected ? "dark:!bg-gray-600" : "dark:!g-gray-800")">
                            <button @ref='programButtonReferences[(Guid.Parse(program.ProgramId), "")]'
                                    @onmouseenter='() => ShowTooltip(Guid.Parse(program.ProgramId), "")'
                                    @onmouseleave="HideTooltip"
                                    class="flex items-center text-white w-full h-full"
                                    @onclick="() => SelectWorkshopArticle(program)">
                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(program.ProgramImage)" class="program-image">
                                <span class="ml-2 dark:!text-white text-black">
                                    @program.Name
                               </span>
                            </button>
                        </div>
                    }
                }
            </div>
        }
        <button class="toggle-button text-white" @onclick="ToggleSidebar">☰</button>
    </div>
    <div class="w-full flex mleft">
        @if (selectedProgram != null && !selectedProgram.SupportsChat)
        {
            <!-- Input box -->
            <div class="box-style text-center p-4 pt-2 overflow-y-auto inputHeight">
                <p class="text-lg font-semibold mb-2">Program Inputs</p>
                @if (selectedProgram != null)
                {
                    <div>
                        @foreach (var input in selectedProgram.ProgramStructure.ProgramStart)
                        {
                            if (input.Name == "Start")
                            {
                                continue;
                            }
                            <div class="item-style bg-white dark:!bg-gray-800 p-4 rounded-lg mb-2 shadow hover:shadow-lg transition">
                                <InputList Id="input.Id" Type="input.Type" Value="selectedProgram.ProgramStructure.InputValues[input.Id]" IsList="input.IsList" Placeholdervalue="input.Name" SendbackValue="SetValue"></InputList>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Center line -->
            <div class="flex flex-col items-center h-full">
                <!-- Vertical Line -->
                <div class="bg-gray-500 w-[2px] flex-grow"></div>

                <!-- Session dropdown -->
                @if (selectedProgram != null && selectedProgram.SupportsSessions)
                {
                    <div class="mt-2">
                        <SelectSession IsDark="true" SelectSessions="setCurrentSession" ProgramId="@selectedProgram.Id.ToString()"></SelectSession>
                    </div>
                }

                <!-- Button -->
                <div class="align-center mb-0 mt-2">
                    <button class="py-1 rounded px-6 h-12 w-48 @(isLoading ? "bg-gray-500 cursor-not-allowed" : isExecutionFailed ? "bg-red-600" : "bg-green-600 hover:bg-green-700") text-white"
                    @onclick="ExecuteProgram"
                    disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span>Loading...</span>
                        }
                        else if (isExecutionFailed)
                        {
                            <span>Failed</span>
                        }
                        else
                        {
                            <span>Execute Program</span>
                        }
                    </button>
                </div>
            </div>

            <!-- Output box -->
            <div class="box-style flex flex-col items-center text-center p-4 pt-2 overflow-y-auto inputHeight">
                <p class="text-lg font-semibold mb-2">Program Outputs</p>
                @if (selectedProgram != null)
                {
                    <div class="flex flex-col justify-end items-end w-full">
                        @foreach (var output in ProgramOutput)
                        {
                            <div class="bg-white dark:!bg-gray-800 p-4 rounded-lg mb-2 shadow hover:shadow-lg transition" style="min-width: 100%;">
                                <OutputDisplay OutputItem="@output" />
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (selectedProgram != null && selectedProgram.SupportsChat)
        {
            <div class="chat-mode-container">
                <!-- Output box for chat -->
                <div class="chat-mode-output p-4 inputHeight">
                    <p class="text-lg font-semibold mb-2">Chat Outputs</p>
                    @if (ProgramChatOutput != null && ProgramChatOutput.ContainsKey(selectedProgram.Id) && ProgramChatOutput[selectedProgram.Id] != null)
                    {
                        @foreach (var output in ProgramChatOutput[selectedProgram.Id])
                        {
                            <div style="min-width: 100%;"> 
                                <OutputDisplay OutputItem="@output" />
                            </div>
                        }
                    }
                </div>

                <!-- Input box for chat -->
                <div class="chat-mode-input p-4 inputHeight">
                    <p class="text-lg font-semibold mb-2">Chat Input</p>
                    @foreach (var input in selectedProgram.ProgramStructure.ProgramStart)
                    {
                        if (input.Name == "Start" || input.Name == "Chat History")
                        {
                            continue;
                        }
                        <div class="item-style bg-white dark:!bg-gray-800 p-4 rounded-lg mb-2 shadow hover:shadow-lg transition">
                            <InputList Id="input.Id" Type="input.Type" Value="selectedProgram.ProgramStructure.InputValues[input.Id]" IsList="input.IsList" Placeholdervalue="input.Name" SendbackValue="SetValue"></InputList>
                        </div>
                    }
                </div>

                <!-- Execute Button for chat -->
                <div class="chat-mode-button flex justify-around">
                    <!-- Clear Output Button -->
                    <button class="py-1 rounded px-6 h-12 w-24 bg-blue-600 hover:bg-blue-700 text-white mr-4"
                            @onclick="ClearOutput">
                        <span>Clear</span>
                    </button>

                    <!-- Existing Execute Button -->
                    <button class="py-1 rounded px-6 h-12 w-48 @(isLoading ? "bg-gray-500 cursor-not-allowed" : isExecutionFailed ? "bg-red-600" : "bg-green-600 hover:bg-green-700") text-white"
                            @onclick="ExecuteProgram"
                            disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span>Loading...</span>
                        }
                        else if (isExecutionFailed)
                        {
                            <span>Failed</span>
                        }
                        else
                        {
                            <span>Execute Program</span>
                        }
                    </button>

                    <!-- Session dropdown -->
                    @if (selectedProgram != null && selectedProgram.SupportsSessions)
                    {
                        <div class="ml-2">
                            <SelectSession IsDark="true" SelectSessions="setCurrentSession" ProgramId="@selectedProgram.Id.ToString()"></SelectSession>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<RadzenNotification @ref="notifyReference" />

<AiDesigner.Client.Modals.ReviewArticle @ref="reviewModal" customProgram="selectedProgram"></AiDesigner.Client.Modals.ReviewArticle>

@code {
    [CascadingParameter(Name = "CascAuth")]
    public AuthenticationState CascAuth { get; set; }

    [CascadingParameter(Name = "Settokens")]
    protected EventCallback<Wallet> SetTokens { get; set; }

    [CascadingParameter(Name = "WorkshopArticles")]
    public List<WorkshopArticle> workshopArticles { get; set; }

    public CustomProgram selectedProgram { get; set; }

    public List<CustomProgram> customPrograms { get; set; }
    public List<CustomProgram> workshopPrograms { get; set; }

    public AiDesigner.Client.Modals.ReviewArticle reviewModal { get; set; }

    private RadzenNotification notifyReference;

    JsonSerializerSettings settings = new JsonSerializerSettings
    {
        TypeNameHandling = TypeNameHandling.Auto,
        Converters = new List<JsonConverter> { new BlockJsonConverter() },
        ContractResolver = new DefaultContractResolver { NamingStrategy = new CamelCaseNamingStrategy() },
        ReferenceLoopHandling = ReferenceLoopHandling.Serialize,
        ObjectCreationHandling = ObjectCreationHandling.Replace
    };

    List<object> ProgramOutput { get; set; } = new List<object>();
    Dictionary<Guid, List<object>> ProgramChatOutput { get; set; } = new Dictionary<Guid, List<object>>();

    Session currentSession = new Session();


    private bool isLoading = false;
    private bool isExecutionFailed = false;

    bool isSidebarActive = true;

    void ToggleSidebar()
    {
        isSidebarActive = !isSidebarActive;
    }

    private Dictionary<(Guid, string), ElementReference> programButtonReferences = new Dictionary<(Guid, string), ElementReference>();

    void ShowTooltip(Guid programId, string source)
    {
        var key = (programId, source);
        if (programButtonReferences.TryGetValue(key, out var elementReference))
        {
            var programsList = source == "custom" ? customPrograms : workshopPrograms;
            var content = programsList.FirstOrDefault(p => p.Id == programId)?.Description;

            if (content != null)
            {
                tooltipService.Open(elementReference, content, new TooltipOptions
                    {
                        Position = TooltipPosition.Top,
                        Style = "max-width: 240px; white-space: normal; word-wrap: break-word;",          
                        Duration = 5000,
                        Delay = 500
                    });
            }
        }
    }

    void HideTooltip()
    {
        tooltipService.Close();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user != null)
        {
            var userIdClaim = user.Claims.FirstOrDefault()?.Value;
            if (Guid.TryParse(userIdClaim, out Guid userId))
            {
                await GetCustomPrograms(userId.ToString());
                await GetWorkshopPrograms(userId.ToString());
            }
        }
    }

    private async Task ExecuteProgram()
    {
        if (selectedProgram != null)
        {
            if (selectedProgram.SupportsChat)
            {
                var userInputValues = selectedProgram.ProgramStructure.InputValues
                    .Where(kvp => kvp.Value != null && kvp.Key != selectedProgram.ProgramStructure.ProgramStart[1].Id)
                    .Select(kvp => kvp.Value)
                    .ToList();

                if (!ProgramChatOutput.ContainsKey(selectedProgram.Id))
                {
                    ProgramChatOutput[selectedProgram.Id] = new List<object>();
                }

                // Add the extracted user input values to the ProgramChatOutput
                ProgramChatOutput[selectedProgram.Id].AddRange(userInputValues);

                // Set the appropriate InputValue to contain the entire chat history
                selectedProgram.ProgramStructure.InputValues[selectedProgram.ProgramStructure.ProgramStart[1].Id] = ProgramChatOutput.Values;
            }

            var nonNullInputValues = selectedProgram.ProgramStructure.InputValues
             .Where(kvp => kvp.Value != null)
             .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);

            if (CascAuth != null)
            {
                var user = CascAuth.User;
                var userIdClaim = user.Claims.FirstOrDefault()?.Value;
                if (Guid.TryParse(userIdClaim, out Guid userId))
                {
                    var url = $"Execute?programKey={selectedProgram.ApiKey}&apiKey={userId}";

                    if (true)
                    {
                        url += $"&isTest=true";
                    }

                    if (selectedProgram.SupportsSessions)
                    {
                        url += $"&sessionId={currentSession?.SessionId}";
                    }

                    isLoading = true;
                    isExecutionFailed = false;
                    try
                    {

                        var requestContent = new StringContent(System.Text.Json.JsonSerializer.Serialize(nonNullInputValues), Encoding.UTF8, "application/json");
                        var response = await Http.PostAsync(url, requestContent);
                        var content = await response.Content.ReadAsStringAsync();

                        var responseContent = await response.Content.ReadAsStringAsync();
                        var outputValues = JsonConvert.DeserializeObject<List<object>>(responseContent);

                        if (response.IsSuccessStatusCode)
                        {
                            ProgramOutput = JsonConvert.DeserializeObject<List<object>>(responseContent);
                            if (selectedProgram.SupportsChat && ProgramChatOutput.ContainsKey(selectedProgram.Id))
                            {
                                ProgramChatOutput[selectedProgram.Id].AddRange(ProgramOutput);
                            }
                            else if (selectedProgram.SupportsChat)
                            {
                                ProgramChatOutput[selectedProgram.Id] = ProgramOutput;
                            }
                        }
                        else
                        {
                            isExecutionFailed = true;
                        }
                    }
                    catch (Exception ex)
                    {
                        isExecutionFailed = true;
                        ShowErrorNotification("Error", $"Error executing program: Server is down or program is faulty");
                        Console.WriteLine($"Error executing program: {ex.Message}");
                    }
                    finally
                    {
                        isLoading = false;
                        if (isExecutionFailed)
                        {
                            StateHasChanged();
                            await Task.Delay(2000);
                            isExecutionFailed = false;
                        }
                        else if (!selectedProgram.HasReview && selectedProgram is CustomProgram)
                        {
                            Random rnd = new Random();
                            if (rnd.Next(1, 21) == 1) // Generates a random number between 1 and 20
                            {
                                await reviewModal.OpenModal();
                            }
                        }
                    }
                    await GetTokens();
                }
            }
            StateHasChanged();
        }
    }

    private async Task GetTokens()
    {
        var user = CascAuth.User;
        if (user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.Claims.FirstOrDefault()?.Value;
            if (!string.IsNullOrEmpty(userIdClaim) && Guid.TryParse(userIdClaim, out Guid userId))
            {
                try
                {
                    var response = await Http.PostAsJsonAsync<Guid>("Chat/Wallet/GetCreateWallet", userId);

                    if (response.IsSuccessStatusCode)
                    {
                        await SetTokens.InvokeAsync(await response.Content.ReadFromJsonAsync<Wallet>());
                    }
                }
                catch (HttpRequestException ex)
                {
                    // Handle or log the HTTP request exception here...
                    Console.WriteLine($"HTTP request exception: {ex.Message}");
                }
                catch (JsonException ex)
                {
                    // Handle or log the deserialization exception here...
                    Console.WriteLine($"Failed to deserialize response: {ex.Message}");
                }
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {

    }

    private void ClearOutput()
    {
        if (selectedProgram != null && ProgramChatOutput.ContainsKey(selectedProgram.Id))
        {
            ProgramChatOutput[selectedProgram.Id].Clear();
        }
    }

    private void SetValue(InputItem inputItem)
    {
        selectedProgram.ProgramStructure.InputValues[inputItem.Id] = inputItem.Data;
    }

    private void SelectWorkshopArticle(WorkshopArticle workshopArticle)
    {

        SetSelectedProgram(workshopPrograms.Where(program => program.Id.ToString() == workshopArticle.ProgramId).First());
    }

    private void SetSelectedProgram(CustomProgram customProgram)
    {
        selectedProgram = customProgram;

        foreach (var input in selectedProgram.ProgramStructure.ProgramStart)
        {
            if (!selectedProgram.ProgramStructure.InputValues.ContainsKey(input.Id))
            {
                selectedProgram.ProgramStructure.InputValues[input.Id] = selectedProgram.ProgramStructure.InputValues.ContainsKey(input.Id)
                    ? selectedProgram.ProgramStructure.InputValues[input.Id]
                    : null;
            }
        }
        foreach (var input in selectedProgram.ProgramStructure.ProgramEnd)
        {
            if (!selectedProgram.ProgramStructure.OutputValues.ContainsKey(input.Id))
            {
                selectedProgram.ProgramStructure.OutputValues[input.Id] = selectedProgram.ProgramStructure.OutputValues.ContainsKey(input.Id)
                    ? selectedProgram.ProgramStructure.OutputValues[input.Id]
                    : null;
            }
        }
        currentSession = null;
    }

    private async Task GetCustomPrograms(string userId)
    {
        string requestUri = $"Chat/Programs/{userId}";
        HttpResponseMessage httpResponse = await Http.GetAsync(requestUri);
        if (httpResponse.IsSuccessStatusCode)
        {
            string content = await httpResponse.Content.ReadAsStringAsync();
            var jsonArray = JArray.Parse(content);

            if (customPrograms == null)
            {
                customPrograms = new List<CustomProgram>();
            }

            foreach (var item in jsonArray)
            {
                var jobject = JObject.Parse(item.ToString());
                var programStructureToken = jobject["programStructure"] as JObject;

                // Initialize default values for locations and positions, similar to UpdatePrograms
                Tuple<int, int> programStartLocation = null, programEndLocation = null;
                Tuple<double, double> cameraPos = null;

                if (programStructureToken != null)
                {
                    // Extract locations and positions, remove from JSON as in UpdatePrograms
                    var startLocationArray = programStructureToken["programStartLocation"] as JArray;
                    if (startLocationArray != null && startLocationArray.Count >= 2)
                    {
                        programStartLocation = new Tuple<int, int>(startLocationArray[0].Value<int>(), startLocationArray[1].Value<int>());
                        programStructureToken.Remove("programStartLocation");
                    }

                    var endLocationArray = programStructureToken["programEndLocation"] as JArray;
                    if (endLocationArray != null && endLocationArray.Count >= 2)
                    {
                        programEndLocation = new Tuple<int, int>(endLocationArray[0].Value<int>(), endLocationArray[1].Value<int>());
                        programStructureToken.Remove("programEndLocation");
                    }

                    var cameraPosArray = programStructureToken["cameraPos"] as JArray;
                    if (cameraPosArray != null && cameraPosArray.Count >= 2)
                    {
                        cameraPos = new Tuple<double, double>(cameraPosArray[0].Value<double>(), cameraPosArray[1].Value<double>());
                        programStructureToken.Remove("cameraPos");
                    }
                }

                // Deserialize into CustomProgram (inherits ProgramObject) with the modified JSON
                var customProgram = JsonConvert.DeserializeObject<CustomProgram>(jobject.ToString(), settings);

                // Reapply the extracted tuples to the CustomProgram's structure
                if (customProgram != null && customProgram.ProgramStructure != null)
                {
                    customProgram.ProgramStructure.ProgramStartLocation = programStartLocation;
                    customProgram.ProgramStructure.ProgramEndLocation = programEndLocation;
                    customProgram.ProgramStructure.CameraPos = cameraPos;
                }

                customPrograms.Add(customProgram);
            }
        }
        else
        {
            Console.WriteLine($"Failed to fetch custom programs. Status code: {httpResponse.StatusCode}");
        }
    }

    private async Task GetWorkshopPrograms(string userId)
    {
        string requestUri = $"Chat/Workshop/{userId}";
        HttpResponseMessage httpResponse = await Http.GetAsync(requestUri);
        if (httpResponse.IsSuccessStatusCode)
        {
            string content = await httpResponse.Content.ReadAsStringAsync();
            var jsonArray = JArray.Parse(content);

            if (workshopPrograms == null)
            {
                workshopPrograms = new List<CustomProgram>();
            }

            foreach (var item in jsonArray)
            {
                var jobject = JObject.Parse(item.ToString());
                var programStructureToken = jobject["programStructure"] as JObject;

                Tuple<int, int> programStartLocation = null, programEndLocation = null;
                Tuple<double, double> cameraPos = null;

                if (programStructureToken != null)
                {
                    var startLocationArray = programStructureToken["programStartLocation"] as JArray;
                    if (startLocationArray != null && startLocationArray.Count >= 2)
                    {
                        programStartLocation = new Tuple<int, int>(startLocationArray[0].Value<int>(), startLocationArray[1].Value<int>());
                        programStructureToken.Remove("programStartLocation");
                    }

                    var endLocationArray = programStructureToken["programEndLocation"] as JArray;
                    if (endLocationArray != null && endLocationArray.Count >= 2)
                    {
                        programEndLocation = new Tuple<int, int>(endLocationArray[0].Value<int>(), endLocationArray[1].Value<int>());
                        programStructureToken.Remove("programEndLocation");
                    }

                    var cameraPosArray = programStructureToken["cameraPos"] as JArray;
                    if (cameraPosArray != null && cameraPosArray.Count >= 2)
                    {
                        cameraPos = new Tuple<double, double>(cameraPosArray[0].Value<double>(), cameraPosArray[1].Value<double>());
                        programStructureToken.Remove("cameraPos");
                    }
                }

                var customProgram = JsonConvert.DeserializeObject<CustomProgram>(jobject.ToString(), settings);
                if (customProgram != null && customProgram.ProgramStructure != null)
                {
                    customProgram.ProgramStructure.ProgramStartLocation = programStartLocation;
                    customProgram.ProgramStructure.ProgramEndLocation = programEndLocation;
                    customProgram.ProgramStructure.CameraPos = cameraPos;
                }

                workshopPrograms.Add(customProgram);
            }
        }
        else
        {
            Console.WriteLine($"Failed to fetch workshop programs. Status code: {httpResponse.StatusCode}");
        }
    }

    private async Task OnSingleFileChanged(InputFileChangeEventArgs e, Guid id)
    {
        var file = e.File;
        string[] imageTypes = new[] { "image/jpeg", "image/png" };

        if (file != null && imageTypes.Contains(file.ContentType))
        {
            // Resizing the image
            var resized = await file.RequestImageFileAsync(file.ContentType, 260, 260);

            var buffer = new byte[resized.Size];
            await using var stream = resized.OpenReadStream((int)resized.Size);
            await stream.ReadAsync(buffer, 0, (int)resized.Size);

            selectedProgram.ProgramStructure.InputValues[id] = buffer;
        }
    }

    private async Task OnSingleAudioFileChanged(InputFileChangeEventArgs e, Guid inputId)
    {
        var file = e.File;
        if (file != null)
        {
            using (var ms = new MemoryStream())
            {
                await file.OpenReadStream().CopyToAsync(ms);
                var bytes = ms.ToArray();
                // Now 'bytes' is a byte array you can use.
                selectedProgram.ProgramStructure.InputValues[inputId] = bytes;
            }
        }
    }

    private void setCurrentSession(Session session)
    {
        currentSession = session;
    }

    private void ShowErrorNotification(string summary, string detail)
    {
        var message = new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = summary,
                Detail = detail,
                Duration = 5000 // Duration in milliseconds
            };
        notificationService.Notify(message); // Using the instance 'notificationService'
    }
}

@using Microsoft.AspNetCore.Authorization
@using NodeBaseApi.Version2;
@inject HttpClient Http;
@inject AuthenticationStateProvider AuthenticationStateProvider;
@attribute [Authorize]

<div class="flex justify-center items-center">
    <div style="width: 83%;" class="content-center">
        <div class="flex flex-wrap gap-4 mt-8 ml-0">
            @if (Articles != null && Articles.Count > 0)
            {
                @foreach (var article in Articles.Skip((CurrentPage - 1) * 20).Take(20))
                {
                    <button class="w-72 h-auto p-0 rounded bg-gray-200 dark:bg-gray-700 text-black dark:text-white flex flex-col items-center justify-center" @onclick="() => SetSelectedArticle(article)">
                        <!-- Add Image Here -->
                        @*                         <AiDesigner.Client.Components.ShowImage ImageData="article.ProgramImage"></AiDesigner.Client.Components.ShowImage>
                *@                      <img src="@($"data:image/png;base64,{Convert.ToBase64String(article.ProgramImage)}")" alt="@article.Name" style="width: 100%; height: 16.25rem; object-fit: cover; border-radius: 0.25rem; margin-bottom: 0.5rem;" loading="lazy" />
                        <h1 class="w-full text-left dark:text-white mb-0 text-xl ml-4">@article.Name</h1>
                        <p class="w-full text-left dark:text-white ml-4">@article.AuthorName</p>
                        <br />
                        <hr style="width: 100%; margin-left: auto; margin-right: auto; margin-top: -1rem;">
                        <div class="flex justify-between w-full" style="margin-bottom: -1.5rem;">
                            <p class="text-left dark:text-white text-lg m-1 ml-3">@article.SearchClass</p>
                        </div>
                        <br />
                    </button>
                }
            }
            else
            {
                for (int i = 0; i < 20; i++)
                {
                    <button class="w-72 h-auto p-0 rounded bg-gray-200 dark:bg-gray-700 text-black dark:text-white flex flex-col items-center justify-center">
                        <!-- Placeholder for Image -->
                        <div style="width: 100%; height: 16.25rem; border-radius: 0.25rem; margin-bottom: 0.5rem;" class="bg-gray-700"></div>

                        <!-- Placeholder for Title -->
                        <div class="w-1/3 bg-gray-300 dark:bg-gray-600 h-6 mb-2 ml-4 self-start"></div>

                        <!-- Placeholder for Author Name -->
                        <div class="w-2/3 bg-gray-300 dark:bg-gray-600 h-5 ml-4 self-start"></div>

                        <br />

                        <hr style="width: 100%; margin-left: auto; margin-right: auto; margin-top: -1rem;">

                        <br />
                    </button>
                }
            }
        </div>
    </div>
</div>


<div class="flex justify-center items-center">
    <div style="width:83%;">
        <div class="flex justify-center mt-8 space-x-4 py-2 bg-gray-100 dark:bg-gray-700">
            @if (CurrentPage > 1)
            {
                <button @onclick="() => SetCurrentPage(1)" class="px-4 py-2 text-white bg-gray-600 rounded hover:!bg-gray-500">First</button>
                <button @onclick="() => SetCurrentPage(CurrentPage - 1)" class="px-4 py-2 text-white bg-gray-600 rounded hover:bg-gray-500">Previous</button>
            }

            @for (var i = Math.Max(1, CurrentPage - PageRange); i <= Math.Min(TotalPages, CurrentPage + PageRange); i++)
            {
                var pageIndex = i;
                <button @onclick="() => SetCurrentPage(pageIndex)" class="px-4 py-2 text-white @(CurrentPage == pageIndex ? "bg-gray-500" : "bg-gray-600") rounded hover:bg-gray-500">@pageIndex</button>
            }

            @if (CurrentPage < TotalPages)
            {
                <button @onclick="() => SetCurrentPage(CurrentPage + 1)" class="px-4 py-2 text-white bg-gray-600 rounded hover:bg-gray-500">Next</button>
                <button @onclick="() => SetCurrentPage(TotalPages)" class="px-4 py-2 text-white bg-gray-600 rounded hover:bg-gray-500">Last</button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<WorkshopArticle> Articles { get; set; }

    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    [Parameter]
    public EventCallback<WorkshopArticle> OnSelectedArticle { get; set; }

    [Parameter]
    public int CurrentPage { get; set; }

    [CascadingParameter(Name = "CascAuth")]
    public AuthenticationState CascAuth { get; set; }

    private int PageRange { get; set; } = 2; // Change this value based on your requirements
    public int TotalPages { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        TotalPages = (int)Math.Ceiling(decimal.Divide(Articles.Count, 20));
    }

    private async Task SetCurrentPage(int page)
    {
        CurrentPage = page;
        await OnPageChanged.InvokeAsync(CurrentPage);
    }

    private void SetSelectedArticle(WorkshopArticle article)
    {
        OnSelectedArticle.InvokeAsync(article);
    }
}


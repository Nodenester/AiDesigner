@code {
    [Parameter]
    public Tuple<List<WorkshopArticle>, List<WorkshopArticle>, List<WorkshopArticle>, List<WorkshopArticle>> WorkshopLists {get;set;}

    [Parameter]
    public WorkshopArticle SelectedArticle { get; set; }

    [Parameter]
    public EventCallback<string> SelectAuthor { get; set; }

    [Parameter]
    public EventCallback<WorkshopArticle> OnSelectedArticle { get; set; }

    protected override async Task OnInitializedAsync()
    {

    }

    private void SetSelectedArticle(WorkshopArticle article)
    {
        SelectedArticle = article;
        OnSelectedArticle.InvokeAsync(SelectedArticle);
    }
}

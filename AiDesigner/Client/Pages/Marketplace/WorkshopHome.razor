@code {
    public List<WorkshopArticle> PopularArticles { get; set; }
    public List<WorkshopArticle> NodeNestorArticles { get; set; }
    public List<WorkshopArticle> NewArticles { get; set; }
    public List<WorkshopArticle> MostDownloadedArticles { get; set; }

    [Parameter]
    public WorkshopArticle SelectedArticle { get; set; }

    [Parameter]
    public EventCallback<string> SelectAuthor { get; set; }

    [Parameter]
    public EventCallback<WorkshopArticle> OnSelectedArticle { get; set; }

    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        if(IsLoading)
        {
            IsLoading = false;
            PopularArticles = await Http.GetFromJsonAsync<List<WorkshopArticle>>("Workshop/most-popular");
            NodeNestorArticles = await Http.GetFromJsonAsync<List<WorkshopArticle>>("Workshop/author");
            NewArticles = await Http.GetFromJsonAsync<List<WorkshopArticle>>("Workshop/newest");
            MostDownloadedArticles = await Http.GetFromJsonAsync<List<WorkshopArticle>>("Workshop/most-downloaded/top");
            StateHasChanged();
        }
    }

    private void SetSelectedArticle(WorkshopArticle article)
    {
        SelectedArticle = article;
        OnSelectedArticle.InvokeAsync(SelectedArticle);
    }
}

@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="row start-1">
    <div class="col-md-4 loginPanel">
        <h1 style="display: flex; align-items: center; justify-content: center; color: white;">@ViewData["Title"]</h1>
        <h2 style="text-align: center; color: white;">Enter your email.</h2>
        <hr />
        <section>
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <button type="submit" class="w-100 btn btn-lg btn-primary" style="background-color: #2ea44f; border: none;">Reset Password</button>
            </form>
        </section>
    </div>
</div>

<style>
    /* Inherits styles from the Login page for consistency */
    .row.start-1 {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 85vh; /* This will take the full height of the viewport */
        background-color: #353535; /* Dark background for the whole container */
    }

    .loginPanel {
        background-color: #2b2b2b; /* Darker background for the login panel */
        padding: 20px;
        border-radius: 8px;
    }

    h1, h2 {
        color: #eaeaea; /* Lighter text color for contrast */
    }

    .form-control {
        background-color: #353535 !important;
        color: #eaeaea;
        border: none;
        border-radius: 4px;
        padding: 10px 15px;
        outline: none;
    }

        .form-control:focus {
            background-color: #353535 !important;
            box-shadow: none;
            color: #eaeaea;
            border: none !important;
            outline: none;
        }

    .form-label {
        color: #eaeaea;
    }

    button[type=submit] {
        background-color: #2ea44f;
        border: none;
    }

        button[type=submit]:hover {
            background-color: #249739; /* A slightly darker green for hover */
        }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

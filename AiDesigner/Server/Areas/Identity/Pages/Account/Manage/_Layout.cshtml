@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div class="row manageAccount">
@*     <div class="col-md-3 manageNav">
        <h1 class="" style="display: flex; align-items: center; justify-content: center; color: white;">Manage Account</h1>
        <partial name="_ManageNav" />
    </div> *@
    <div class="col-md-9 manageBody">
@*         <h2>Change your account settings</h2>
 *@     @RenderBody()
    </div>
</div>

<style>
    /* Styling for the manage account row */
    .row.manageAccount {
        display: flex;
        justify-content: center;
        align-items: center; /* This is for vertical centering; remove if not needed */
        height: 85vh; /* Assuming you still want this height */
        background-color: #353535; /* Assuming you still want this background color */
    }

/*     #2b2b2b
    #353535 */
    /* Adjust the styling of the manageNav */
    .manageNav {
        background-color: #2b2b2b;
        padding: 20px;
        border-radius: 8px;
        color: #eaeaea; 
    }

    /* Adjust the styling of the manageBody */
    .manageBody {
        width: auto; /* Let it take only as much width as needed, remove 'fit-content' if previously set */
        min-width: 30%; 
        padding: 20px;
        border-radius: 8px;
        background-color: #2b2b2b;
    }

    h2 {
        color: #eaeaea; 
    }
</style>

@section Scripts {
    @RenderSection("Scripts", required: false)
}

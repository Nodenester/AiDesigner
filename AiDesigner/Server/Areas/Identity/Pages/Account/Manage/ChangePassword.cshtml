@page
@model ChangePasswordModel

@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="profileContainer">
    <h3>@ViewData["Title"]</h3>
    <partial name="_StatusMessage" for="StatusMessage" />

    <form id="change-password-form" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <!-- Old Password Field -->
        <div class="form-floating mb-3">
            <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Please enter your old password." />
            <label asp-for="Input.OldPassword" class="form-label">Old Password</label>
            <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
        </div>

        <!-- New Password Field -->
        <div class="form-floating mb-3">
            <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Please enter your new password." />
            <label asp-for="Input.NewPassword" class="form-label">New Password</label>
            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
        </div>

        <!-- Confirm New Password Field -->
        <div class="form-floating mb-3">
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Please confirm your new password." />
            <label asp-for="Input.ConfirmPassword" class="form-label">Confirm New Password</label>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <!-- Update Password Button -->
        <button id="update-password-button" type="submit" class="profileBtn">Update password</button>
    </form>
</div>

<style>
    .profileContainer {
        background-color: #2b2b2b;
        padding: 30px;
        border-radius: 8px;
        color: #eaeaea;
        max-width: 600px;
        /*         margin: auto; */
    }

    h3 {
        text-align: center;
        margin-bottom: 25px;
    }

    .form-control {
        background-color: #353535;
        color: #eaeaea;
        border: none;
        border-radius: 4px;
        padding: 10px 15px;
        outline: none;
    }

        .form-control:focus {
            background-color: #353535;
            box-shadow: none;
            color: #eaeaea;
            border: none !important;
            outline: none;
        }

        .form-control:disabled {
            background-color: #353535;
            opacity: 0.7;
            border: none !important;
            /*          Gives a slight faded effect to indicate it's disabled color: #eaeaea; */
        }

    .form-label {
        color: #eaeaea;
    }

    .text-danger {
        color: #ff6b6b;
    }

    .profileBtn {
        background-color: #2ea44f;
        border: none;
        padding: 10px 15px;
        font-size: 18px;
        border-radius: 4px;
        transition: background-color 0.3s;
        width: 100%;
        color: #fff;
    }

        .profileBtn:hover {
            background-color: #249739;
        }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@page
@model LoginModel
@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations

<div class="row start-1">
    <div class="col-md-4 loginPanel">
        <h1 class="" style="display: flex; align-items: center; justify-content: center; color: white;">Login</h1>
        <section>
            <form id="account" method="post">
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Name" class="form-control" autocomplete="name" aria-required="true" placeholder="Your user name" />
                    <label asp-for="Input.Name" class="form-label">Name</label>
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label" style="color: white;">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div>
                    <button id="login-submit" type="submit" style="background-color: #2ea44f;" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div>
            </form>
        </section>
    </div>
</div>

<style>
    /* Set the background of the container to a dark shade */
    .row.start-1 {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 85vh; /* This will take the full height of the viewport */
        background-color: #353535; /* Dark background for the whole container */
    }

    /* Adjust the styling of the login panel */
    .loginPanel {
        background-color: #2b2b2b; /* Darker background for the login panel */
        padding: 20px;
        border-radius: 8px;
    }

    /* Style for the header text */
    h1 {
        color: #eaeaea; /* Lighter text color for contrast */
    }

    /* Checkbox label color */
    .checkbox .form-label {
        color: #eaeaea; /* Lighter text color for contrast */
    }

    /* Button styling */
    #login-submit {
        background-color: #2ea44f;
        border: none;
    }

        #login-submit:hover {
            background-color: #249739; /* A slightly darker green for hover */
        }

    .form-control {
        background-color: #353535 !important;
        color: #eaeaea;
        border: none;
        border-radius: 4px;
        padding: 10px 15px;
        outline: none;
    }

        .form-control:focus {
            background-color: #353535 !important;
            box-shadow: none;
            color: #eaeaea;
            border: none !important;
            outline: none;
        }

        .form-control:disabled {
            background-color: #353535 !important;
            opacity: 0.7;
            border: none !important;
            /*          Gives a slight faded effect to indicate it's disabled color: #eaeaea; */
        }

    .form-label {
        color: #eaeaea;
    }

    .form-check-input {
        width: 1.5rem;
        height: 1.5rem;
        appearance: none;
        outline: none;
        border: 1px solid #ccc; /* You can change this color to match your design */
        border-radius: 4px; /* Optional: for rounded corners */
    }

        .form-check-input:checked {
            background-color: #2ea44f;
            border-color: #2ea44f; /* Optional: to ensure border color matches background */
        }

        /* For better cross-browser compatibility */
        .form-check-input:focus {
            outline: none;
        }

        /* For better appearance on Webkit browsers like Chrome/Safari */
        .form-check-input::-webkit-checkbox {
            appearance: none;
        }

    input:-webkit-autofill,
    input:-webkit-autofill:hover,
    input:-webkit-autofill:focus,
    textarea:-webkit-autofill,
    textarea:-webkit-autofill:hover,
    textarea:-webkit-autofill:focus,
    select:-webkit-autofill,
    select:-webkit-autofill:hover,
    select:-webkit-autofill:focus {
        border: 0px solid #e8e8e8;
        -webkit-text-fill-color: #fff;
        -webkit-box-shadow: 0 0 0px 1000px #404040 inset;
        transition: background-color 5000s ease-in-out 0s;
    }

    /* For Mozilla Firefox */
    input:-moz-autofill,
    input:-moz-autofill:focus,
    textarea:-moz-autofill,
    textarea:-moz-autofill:focus {
        border: 0px solid #e8e8e8;
        -moz-text-fill-color: #fff;
        -moz-box-shadow: 0 0 0px 1000px #404040 inset;
        transition: background-color 5000s ease-in-out 0s;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
